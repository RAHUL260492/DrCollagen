<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <meta name="theme-color" content="#1a1225">

  <link rel="canonical" href="{{ canonical_url }}">
  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- else -%}
    <meta name="description" content="Japanese marine collagen, micro-hydrolysed to under 2,000 Daltons and stacked with the co-factors collagen synthesis needs. Four formulas for skin, joints, body composition, and gut.">
  {%- endif -%}

  <!-- Open Graph -->
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:title" content="{{ page_title | escape }}">
  {%- if page_description -%}
    <meta property="og:description" content="{{ page_description | escape }}">
  {%- else -%}
    <meta property="og:description" content="Japanese marine collagen, micro-hydrolysed to under 2,000 Daltons. Four formulas for skin, joints, body composition, and gut.">
  {%- endif -%}
  <meta property="og:type" content="website">
  {%- if settings.og_image != blank -%}
    <meta property="og:image" content="{{ settings.og_image | image_url: width: 1200 }}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:image" content="{{ settings.og_image | image_url: width: 1200 }}">
  {%- endif -%}

  <!-- Fonts: Playfair Display + DM Sans — trimmed from 13 weights to 8.
       Enough to preserve the existing homepage/product weights (300-700)
       while removing the redundant italic + 600 mid-bolds. -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;700&family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">

  {%- comment -%} Preload first hero frame only on the homepage for fast LCP {%- endcomment -%}
  {%- if template.name == 'index' -%}
    <link rel="preload" as="image" href="{{ 'hero-frame-0001.webp' | asset_url }}">
  {%- endif -%}

  <!-- Shared luxury theme system -->
  {{ 'theme.css' | asset_url | stylesheet_tag }}

  <!-- Motion One — must load SYNCHRONOUSLY because the homepage and product
       snippets reference Motion.animate / Motion.inView inline. Adding defer
       here will cause those inline scripts to throw ReferenceError and the
       homepage loader will hang. -->
  <script src="https://cdn.jsdelivr.net/npm/motion@11.11.17/dist/motion.js"></script>

  <!-- Shared luxury runtime — safe to defer, only listens for DOMContentLoaded -->
  <script src="{{ 'theme.js' | asset_url }}" defer></script>

  {{ content_for_header }}
</head>
<body class="template-{{ template.name | handle }}{% if template.suffix %} template-{{ template.name | handle }}--{{ template.suffix | handle }}{% endif %}">

  <a class="skip-to-content" href="#main">Skip to content</a>

  {%- comment -%}
    Pages with their own per-page nav + film-grain + particles + cursor:
    the homepage and the four flagship product landing pages. We skip
    rendering the global header/footer AND the global cinematic chrome
    on those, so layers don't double up.
  {%- endcomment -%}
  {%- assign has_inline_nav = false -%}
  {%- if template.name == 'index' -%}{%- assign has_inline_nav = true -%}{%- endif -%}
  {%- if template.name == 'page' -%}
    {%- case page.handle -%}
      {%- when 'collabloom' or 'skelecoll' or 'collatrim' or 'metastable' -%}
        {%- assign has_inline_nav = true -%}
    {%- endcase -%}
  {%- endif -%}

  {%- unless has_inline_nav -%}
    {%- comment -%} Global cinematic chrome for fallback pages {%- endcomment -%}
    <div class="dc-film-grain" aria-hidden="true"></div>
    <div class="dc-vignette" aria-hidden="true"></div>
    <canvas class="dc-particles" aria-hidden="true"></canvas>

    {% section 'header' %}
  {%- endunless -%}

  <main id="main" role="main">
    {{ content_for_layout }}
  </main>

  {%- unless has_inline_nav -%}
    {% section 'footer' %}
  {%- endunless -%}

  <button class="dc-back-to-top" aria-label="Back to top" type="button">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="12" y1="19" x2="12" y2="5"></line>
      <polyline points="5 12 12 5 19 12"></polyline>
    </svg>
  </button>

</body>
</html>
