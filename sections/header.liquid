{%- comment -%}
  Luxury header — used on all templates except the homepage and the four
  flagship product landing pages (those carry their own per-page nav).
  Sticky, glass-morphism on scroll, magnetic gold underlines, mobile drawer.
{%- endcomment -%}

<style>
  .dc-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 500;
    padding: 22px 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition:
      background 400ms var(--dc-ease-soft),
      padding 400ms var(--dc-ease-soft),
      backdrop-filter 400ms var(--dc-ease-soft),
      border-color 400ms var(--dc-ease-soft);
  }
  .dc-header.is-scrolled {
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(18px) saturate(140%);
    -webkit-backdrop-filter: blur(18px) saturate(140%);
    border-bottom-color: rgba(0, 0, 0, 0.05);
    padding: 14px 48px;
  }

  .dc-logo {
    font-family: var(--dc-heading);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--dc-ink);
    text-decoration: none;
  }
  .dc-logo span { color: var(--dc-accent); }

  .dc-nav {
    display: flex;
    align-items: center;
    gap: 36px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .dc-nav a {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--dc-fg-muted);
    position: relative;
    padding: 4px 0;
    transition: color 300ms var(--dc-ease-soft);
  }
  .dc-nav a::after {
    content: "";
    position: absolute;
    left: 0; right: 100%;
    bottom: -2px;
    height: 1px;
    background: var(--dc-ink);
    transition: right var(--dur-med) var(--ease);
  }
  .dc-nav a:hover,
  .dc-nav a[aria-current="page"] { color: var(--dc-ink); }
  .dc-nav a:hover::after,
  .dc-nav a[aria-current="page"]::after { right: 0; }

  .dc-header-actions {
    display: flex;
    align-items: center;
    gap: 22px;
  }
  .dc-cart-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--dc-ink);
    padding: 8px 4px;
    transition: color 300ms var(--dc-ease-soft);
  }
  .dc-cart-link:hover { color: var(--dc-accent); }
  /* Quiet cart count — no hover scale, no color flip. */
  .dc-cart-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 22px;
    height: 22px;
    padding: 0 7px;
    background: var(--dc-ink);
    color: #fff;
    border-radius: var(--radius-pill);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0;
  }

  /* Hamburger */
  .dc-hamburger {
    display: none;
    width: 38px; height: 38px;
    background: transparent;
    border: none;
    cursor: pointer;
    position: relative;
  }
  .dc-hamburger span {
    position: absolute;
    left: 8px; right: 8px;
    height: 1.5px;
    background: var(--dc-ink);
    transition: transform 350ms var(--dc-ease-spring), opacity 200ms;
  }
  .dc-hamburger span:nth-child(1) { top: 14px; }
  .dc-hamburger span:nth-child(2) { top: 19px; }
  .dc-hamburger span:nth-child(3) { top: 24px; }
  .dc-hamburger[aria-expanded="true"] span:nth-child(1) { transform: translateY(5px) rotate(45deg); }
  .dc-hamburger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .dc-hamburger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-5px) rotate(-45deg); }

  /* Mobile drawer */
  .dc-drawer {
    position: fixed;
    top: 0; right: 0;
    width: min(86vw, 380px);
    height: 100vh;
    background: var(--dc-bg);
    box-shadow: -18px 0 60px rgba(0, 0, 0, 0.18);
    transform: translateX(100%);
    transition: transform 500ms var(--dc-ease-spring);
    padding: 96px 32px 32px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    z-index: 480;
  }
  .dc-drawer.is-open { transform: translateX(0); }
  .dc-drawer a {
    display: block;
    font-family: var(--dc-heading);
    font-size: 22px;
    font-weight: 400;
    color: var(--dc-ink);
    text-decoration: none;
    padding: 12px 0;
    border-bottom: 1px solid var(--dc-line);
    opacity: 0;
    transform: translateX(20px);
    transition: opacity 500ms var(--dc-ease-spring), transform 500ms var(--dc-ease-spring), color 200ms;
  }
  .dc-drawer.is-open a {
    opacity: 1;
    transform: translateX(0);
  }
  .dc-drawer.is-open a:nth-child(1) { transition-delay: 0.10s; }
  .dc-drawer.is-open a:nth-child(2) { transition-delay: 0.16s; }
  .dc-drawer.is-open a:nth-child(3) { transition-delay: 0.22s; }
  .dc-drawer.is-open a:nth-child(4) { transition-delay: 0.28s; }
  .dc-drawer.is-open a:nth-child(5) { transition-delay: 0.34s; }
  .dc-drawer.is-open a:nth-child(6) { transition-delay: 0.40s; }
  .dc-drawer a:hover { color: var(--dc-accent); }

  body.dc-drawer-open { overflow: hidden; }
  body.dc-drawer-open::before {
    content: "";
    position: fixed; inset: 0;
    background: rgba(0, 0, 0, 0.42);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 470;
  }

  @media (max-width: 880px) {
    .dc-header { padding: 16px 24px; }
    .dc-header.is-scrolled { padding: 12px 24px; }
    .dc-nav { display: none; }
    .dc-hamburger { display: block; }
  }

    /* Logo lockup: Dr Collagen + "Formulated by Doctors" subtitle */
    .nav-logo {
      display: inline-flex;
      flex-direction: column;
      align-items: flex-start;
      line-height: 1;
      gap: 3px;
    }
    .nav-logo__main { font: inherit; }
    .nav-logo__sub {
      font-size: 8px;
      font-weight: 700;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: rgba(0,0,0,.55);
      white-space: nowrap;
    }
    nav.in-dark-section .nav-logo__sub,
    nav.scrolled-dark .nav-logo__sub { color: rgba(255,255,255,.65); }
    .footer-brand,
    .logo {
      display: inline-flex;
      flex-direction: column;
      align-items: flex-start;
      line-height: 1;
      gap: 4px;
    }
    .footer-brand__main, .logo__main { font: inherit; }
    .footer-brand__sub, .logo__sub {
      font-size: 8.5px;
      font-weight: 700;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: rgba(255,255,255,.55);
      white-space: nowrap;
    }
    /* Global section-header.liquid uses .dc-logo */
    .dc-logo {
      display: inline-flex;
      flex-direction: column;
      align-items: flex-start;
      line-height: 1;
      gap: 3px;
    }
    .dc-logo__main { font: inherit; }
    .dc-logo__sub {
      font-size: 8px;
      font-weight: 700;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: rgba(0,0,0,.55);
      white-space: nowrap;
    }

  </style>

<header class="dc-header" data-dc-nav role="banner">
  <a href="{{ routes.root_url }}" class="dc-logo"><span class="dc-logo__main">Dr<span> Collagen</span></span><span class="dc-logo__sub">Formulated by Doctors</span></a>

  <nav aria-label="Primary">
    <ul class="dc-nav">
      <li><a href="{{ routes.root_url }}">Home</a></li>
      <li><a href="/collections/all">Shop</a></li>
      <li><a href="/pages/collabloom">Collabloom</a></li>
      <li><a href="/pages/skelecoll">Skelecoll</a></li>
      <li><a href="/pages/collatrim">Collatrim</a></li>
      <li><a href="/pages/metastable">Metastable</a></li>
    </ul>
  </nav>

  <div class="dc-header-actions">
    <a href="{{ routes.cart_url }}" class="dc-cart-link" aria-label="Cart with {{ cart.item_count }} items">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="9" cy="21" r="1"></circle>
        <circle cx="20" cy="21" r="1"></circle>
        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
      </svg>
      <span class="dc-cart-count">{{ cart.item_count }}</span>
    </a>
    <button class="dc-hamburger" data-dc-drawer-toggle aria-expanded="false" aria-label="Open menu" aria-controls="dc-drawer" type="button">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<aside class="dc-drawer" id="dc-drawer" data-dc-drawer aria-hidden="true" aria-label="Mobile menu">
  <a href="{{ routes.root_url }}">Home</a>
  <a href="/collections/all">Shop All</a>
  <a href="/pages/collabloom">Collabloom</a>
  <a href="/pages/skelecoll">Skelecoll</a>
  <a href="/pages/collatrim">Collatrim</a>
  <a href="/pages/metastable">Metastable</a>
</aside>

{%- comment -%}Spacer so content doesn't sit under fixed header{%- endcomment -%}
