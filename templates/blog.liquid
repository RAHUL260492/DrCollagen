{% comment %}Blog listing — editorial luxury layout{% endcomment %}

<style>
  .blog-page {
    max-width: 1140px;
    margin: 0 auto;
    padding: var(--space-6) clamp(20px, 4vw, 48px);
    font-family: var(--dc-body);
    color: var(--dc-fg);
  }
  .blog-head {
    text-align: center;
    margin-bottom: 64px;
  }
  .blog-head h1 {
    font-family: var(--dc-heading);
    font-size: clamp(38px, 5.4vw, 60px);
    font-weight: 400;
    margin: 0;
    color: var(--dc-ink);
    letter-spacing: -0.015em;
  }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 48px;
  }
  .blog-card {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: transform 500ms var(--dc-ease-spring);
  }
  .blog-card:hover { transform: translateY(-4px); }
  .blog-card-media {
    border-radius: var(--dc-radius-md);
    overflow: hidden;
    margin-bottom: 18px;
    aspect-ratio: 16 / 10;
    background: var(--dc-bg-soft);
  }
  .blog-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-slow) var(--ease);
  }
  .blog-card:hover .blog-card-media img { transform: scale(1.03); }
  .blog-card-date {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--dc-accent);
    font-weight: 500;
    margin: 0 0 10px;
  }
  .blog-card-title {
    font-family: var(--dc-heading);
    font-size: 24px;
    font-weight: 400;
    margin: 0 0 12px;
    line-height: 1.3;
    color: var(--dc-ink);
  }
  .blog-card-excerpt {
    font-size: 14px;
    color: var(--dc-fg-muted);
    line-height: 1.7;
    font-weight: 300;
    margin: 0;
  }
</style>

<section class="blog-page">
  <header class="blog-head">
    <p class="dc-eyebrow dc-reveal-up">Journal</p>
    <h1 class="dc-reveal-up dc-delay-1">{{ blog.title }}</h1>
  </header>

  <div class="blog-grid">
    {% for article in blog.articles %}
      <a href="{{ article.url }}" class="blog-card dc-reveal-up{% cycle '', ' dc-delay-1', ' dc-delay-2' %}">
        {% if article.image %}
          <div class="blog-card-media">
            <img src="{{ article.image | image_url: width: 800 }}" alt="{{ article.title | escape }}" loading="lazy">
          </div>
        {% endif %}
        <p class="blog-card-date">{{ article.published_at | date: '%b %d, %Y' }}</p>
        <h2 class="blog-card-title">{{ article.title }}</h2>
        <p class="blog-card-excerpt">{{ article.excerpt_or_content | strip_html | truncatewords: 22 }}</p>
      </a>
    {% endfor %}
  </div>

  {% if paginate.pages > 1 %}
    <nav style="text-align:center;margin-top:64px;font-size:12px;letter-spacing:.2em;text-transform:uppercase;" aria-label="Pagination">
      {{ paginate | default_pagination }}
    </nav>
  {% endif %}
</section>
