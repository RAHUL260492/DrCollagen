<style>
    /* ─── DESIGN TOKENS ─────────────────────────────────────────── */
    :root {
      --accent:       #e8b72e;
      --accent-glow:  rgba(232,183,46,.3);
      --accent-soft:  rgba(232,183,46,.08);
      --gold:         #b8903a;
      --gold-dim:     rgba(184,144,58,.2);
      --bg:           #ffffff;
      --fg:           #1a1225;
      --fg-muted:     #5a5268;
      --fg-subtle:    #6b6472;
      --heading:      'Playfair Display', Georgia, serif;
      --body:         'DM Sans', -apple-system, sans-serif;

      /* Legacy aliases to prevent breakage: */
      --ink:          var(--bg);
      --warm-white:   var(--fg);
      --warm-dim:     var(--fg-muted);
      --muted:        var(--fg-subtle);
      --blush:        var(--bg);
      --charcoal:     var(--bg);
      --surface:      var(--bg);
      --cream:        var(--bg);
    }
    /* Token naming is legacy from a dark-to-light redesign. Semantic intent:
       --ink = page background (white); --warm-white = primary text. A full
       rename is pending — do not add new uses of --blush/--cream/--surface/
       --charcoal; prefer --ink. */

    /* ─── METALLIC GOLD TEXT TREATMENT ───────────────────────────── */
    /* Applied to italicized emphasis in headings — luminous shining gold */
    .st-title em, .st-h2 em, .st-quote em,
    .section-title em, .about-text h2 em, .science-text h2 em,
    .showcase-heading em {
      /* Lightest stop raised from #fff5c2 (1.1:1 on white) to #d9a93a (≈4.5:1)
         so gold-shimmer headings meet WCAG AA across the gradient band. */
      background: linear-gradient(
        135deg,
        #d9a93a 0%,
        #c99a2a 22%,
        #c29123 42%,
        #b88a24 58%,
        #8a6a1e 78%,
        #5e4a14 100%
      );
      background-size: 220% 220%;
      -webkit-background-clip: text; background-clip: text;
      -webkit-text-fill-color: transparent; color: transparent;
      filter: drop-shadow(0 1px 0 rgba(255,240,170,.55))
              drop-shadow(0 0 14px rgba(232,183,46,.45));
      animation: gold-shimmer 5.5s ease-in-out infinite;
    }
    @keyframes gold-shimmer {
      0%,100% { background-position: 0% 50%; }
      50%     { background-position: 100% 50%; }
    }

    /* ─── RESET ─────────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--body);
      background: var(--ink);
      color: var(--warm-white);
      overflow-x: hidden;
      cursor: default;
    }
    img { display: block; max-width: 100%; }
    a { text-decoration: none; color: inherit; }
    button { cursor: pointer; border: none; background: none; font-family: var(--body); }

    /* ─── FOCUS VISIBILITY (WCAG 2.4.7) ─────────────────────────── */
    :focus { outline: none; }
    a:focus-visible, button:focus-visible, .btn-primary:focus-visible,
    .btn-outline:focus-visible, .nav-cta:focus-visible,
    .product-card:focus-visible, .pillar-card:focus-visible,
    .ingr-card:focus-visible, [tabindex]:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 3px;
      border-radius: 8px;
    }
    /* Skip-to-content link (visually hidden until focused) */
    .skip-link {
      position: absolute;
      left: -9999px;
      top: 0;
      z-index: 10000;
      padding: 12px 18px;
      background: var(--warm-white);
      color: #fff;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: .2em;
      text-transform: uppercase;
      border-radius: 0 0 10px 0;
    }
    .skip-link:focus {
      left: 0;
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    /* ─── CUSTOM CURSOR ──────────────────────────────────────────── */
    #cursor-dot {
      position: fixed; top: 0; left: 0; z-index: 9998;
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--warm-white);
      pointer-events: none;
      transform: translate(-50%,-50%);
      mix-blend-mode: difference;
      transition: width .2s, height .2s;
    }
    #cursor-ring {
      position: fixed; top: 0; left: 0; z-index: 9997;
      width: 36px; height: 36px; border-radius: 50%;
      border: 1.5px solid var(--accent);
      pointer-events: none;
      transform: translate(-50%,-50%);
      transition: border-color .3s, width .3s, height .3s, box-shadow .3s;
    }
    body.hovering #cursor-ring {
      width: 52px; height: 52px;
      box-shadow: 0 0 18px var(--accent-glow);
      border-color: var(--gold);
    }

    /* ─── FILM GRAIN ─────────────────────────────────────────────── */
    #film-grain {
      position: fixed; inset: -50%; z-index: 100;
      width: 200%; height: 200%;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
      background-size: 256px 256px;
      opacity: 0.032;
      pointer-events: none;
      animation: grain-move 0.6s steps(2) infinite;
    }
    @keyframes grain-move {
      0%   { transform: translate(0,0); }
      25%  { transform: translate(-3px,2px); }
      50%  { transform: translate(2px,-3px); }
      75%  { transform: translate(3px,1px); }
      100% { transform: translate(-1px,3px); }
    }

    /* ─── VIGNETTE ───────────────────────────────────────────────── */
    #vignette {
      position: fixed; inset: 0; z-index: 99;
      background: radial-gradient(ellipse at 50% 50%, transparent 55%, rgba(232,183,46,.06) 100%);
      pointer-events: none;
    }

    /* ─── PARTICLES ──────────────────────────────────────────────── */
    #particles-canvas {
      position: fixed; inset: 0; z-index: 15;
      pointer-events: none;
      opacity: 0.45;
    }

    /* ─── LOADER ─────────────────────────────────────────────────── */
    #loader {
      position: fixed; inset: 0; z-index: 9999;
      background: var(--ink);
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      gap: 24px;
      transition: opacity .7s ease, filter .7s ease;
    }
    #loader.fade-out { opacity: 0; filter: blur(8px); pointer-events: none; }
    .loader-brand {
      font-family: var(--heading);
      font-size: clamp(18px, 3vw, 26px);
      font-weight: 300;
      letter-spacing: .35em;
      text-transform: uppercase;
      color: var(--warm-white);
    }
    .loader-lines {
      display: flex; flex-direction: column; gap: 6px; align-items: center;
    }
    .loader-lines span {
      display: block; height: 1px; background: var(--muted);
    }
    .loader-lines span:nth-child(1) { width: 40px; }
    .loader-lines span:nth-child(2) { width: 80px; }
    .loader-track {
      width: 140px; height: 2px; background: rgba(0,0,0,.08); border-radius: 2px; overflow: hidden;
    }
    .loader-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--accent), var(--gold));
      border-radius: 2px;
      width: 0%;
      transition: width .05s linear;
    }
    .loader-pct {
      font-size: 10px; font-weight: 500; letter-spacing: .2em;
      color: var(--muted); text-transform: uppercase;
    }

    /* ─── NAV ────────────────────────────────────────────────────── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 500;
      padding: 24px 48px;
      display: flex; align-items: center; justify-content: space-between;
      transition: background .4s ease, padding .4s ease, backdrop-filter .4s ease, border-color .4s ease;
      border-bottom: 1px solid transparent;
    }
    nav.scrolled {
      background: rgba(255,255,255,.82);
      backdrop-filter: blur(18px) saturate(130%);
      -webkit-backdrop-filter: blur(18px) saturate(130%);
      border-bottom-color: rgba(0,0,0,.05);
      padding: 16px 48px;
    }
    .nav-logo {
      font-family: var(--heading);
      font-size: 20px;
      font-weight: 600;
      letter-spacing: .08em;
    }
    .nav-logo span { color: var(--accent); }
    .nav-links {
      display: flex; gap: 36px; list-style: none;
    }
    .nav-links a {
      font-size: 12px; font-weight: 500;
      letter-spacing: .2em; text-transform: uppercase;
      color: #2a2235;
      transition: color .3s;
      position: relative;
    }
    .nav-links a::after {
      content: ''; position: absolute; bottom: -3px; left: 0; right: 100%;
      height: 1px; background: var(--accent);
      transition: right .3s;
    }
    .nav-links a:hover { color: var(--warm-white); }
    .nav-links a:hover::after { right: 0; }

    /* Products dropdown */
    .nav-links .has-dropdown { position: relative; }
    .nav-links .has-dropdown > a .caret {
      display: inline-block;
      font-size: 10px;
      margin-left: 4px;
      transition: transform .3s;
      letter-spacing: 0;
    }
    .nav-links .has-dropdown:hover > a .caret { transform: rotate(180deg); }
    .nav-links .dropdown {
      position: absolute;
      top: calc(100% + 14px);
      left: -24px;
      min-width: 320px;
      background: rgba(255,255,255,.98);
      backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(0,0,0,.06);
      border-radius: 14px;
      padding: 10px 0;
      box-shadow: 0 22px 60px rgba(0,0,0,.14), 0 2px 6px rgba(0,0,0,.04);
      opacity: 0;
      visibility: hidden;
      transform: translateY(-8px);
      transition: opacity .28s, transform .28s, visibility .28s;
      list-style: none;
      z-index: 200;
    }
    .nav-links .has-dropdown:hover > .dropdown,
    .nav-links .has-dropdown:focus-within > .dropdown {
      opacity: 1; visibility: visible; transform: translateY(0);
    }
    .nav-links .dropdown::before {
      content: '';
      position: absolute;
      top: -14px; left: 0; right: 0; height: 14px;
    }
    .nav-links .dropdown li { list-style: none; }
    .nav-links .dropdown a {
      display: block;
      padding: 12px 22px;
      font-family: var(--heading);
      font-size: 14px;
      font-weight: 400;
      letter-spacing: .02em;
      text-transform: none;
      color: #2a2235;
      transition: background .25s, color .25s, padding-left .25s;
    }
    .nav-links .dropdown a em {
      font-style: normal;
      font-family: var(--body);
      font-size: 10px;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: rgba(42,34,53,.5);
      margin-left: 6px;
    }
    .nav-links .dropdown a sup {
      font-size: 8px;
      vertical-align: super;
    }
    .nav-links .dropdown a::after { display: none; }
    .nav-links .dropdown a:hover {
      background: rgba(0,0,0,.04);
      color: var(--accent);
      padding-left: 26px;
    }
    .nav-links .dropdown a:hover em { color: var(--accent); opacity: .7; }
    .nav-links .dropdown .dropdown-divider {
      height: 1px;
      background: rgba(0,0,0,.07);
      margin: 6px 18px;
    }
    .nav-links .dropdown .view-all {
      font-family: var(--body);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--accent);
    }
    /* Dark-section override for dropdown content */
    nav.in-dark-section .nav-links .dropdown a { color: #2a2235; }
    nav.in-dark-section .nav-links .dropdown a em { color: rgba(42,34,53,.5); }
    .nav-cta {
      font-size: 11px; font-weight: 500; letter-spacing: .2em;
      text-transform: uppercase;
      padding: 10px 24px;
      border: 1px solid rgba(232,205,135,.4);
      color: var(--accent);
      border-radius: 40px;
      transition: background .3s, color .3s, border-color .3s;
    }
    .nav-cta:hover {
      background: var(--accent);
      color: var(--ink);
      border-color: var(--accent);
    }

    /* ─── HAMBURGER (mobile nav toggle) ─────────────────────────── */
    .nav-hamburger {
      display: none;               /* shown via media query at ≤900px */
      width: 44px; height: 44px;   /* WCAG 2.5.5 touch target */
      padding: 0;
      background: transparent;
      border: none;
      position: relative;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
    }
    .nav-hamburger span {
      position: absolute;
      left: 10px; right: 10px;
      height: 1.5px;
      background: var(--warm-white);
      border-radius: 2px;
      transition: transform .3s ease, opacity .3s ease, top .3s ease;
    }
    .nav-hamburger span:nth-child(1) { top: 15px; }
    .nav-hamburger span:nth-child(2) { top: 21px; }
    .nav-hamburger span:nth-child(3) { top: 27px; }
    .nav-hamburger[aria-expanded="true"] span:nth-child(1) { top: 21px; transform: rotate(45deg); }
    .nav-hamburger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
    .nav-hamburger[aria-expanded="true"] span:nth-child(3) { top: 21px; transform: rotate(-45deg); }

    /* ─── MOBILE DRAWER ─────────────────────────────────────────── */
    #mobile-drawer {
      position: fixed; inset: 0; z-index: 490;
      background: rgba(255,255,255,.98);
      backdrop-filter: blur(20px) saturate(130%);
      -webkit-backdrop-filter: blur(20px) saturate(130%);
      display: flex; flex-direction: column;
      padding: 96px 32px 40px;
      opacity: 0; visibility: hidden;
      transform: translateY(-8px);
      transition: opacity .3s ease, transform .3s ease, visibility .3s ease;
    }
    #mobile-drawer.open {
      opacity: 1; visibility: visible; transform: translateY(0);
    }
    #mobile-drawer .drawer-links {
      list-style: none; display: flex; flex-direction: column; gap: 8px;
      margin: 0; padding: 0;
    }
    #mobile-drawer .drawer-links > li > a,
    #mobile-drawer .drawer-links .drawer-heading {
      display: block;
      padding: 16px 12px;
      font-family: var(--heading);
      font-size: 22px;
      font-weight: 400;
      color: #2a2235;
      letter-spacing: .02em;
      border-bottom: 1px solid rgba(0,0,0,.06);
    }
    #mobile-drawer .drawer-sub {
      list-style: none;
      padding: 4px 0 12px 16px;
      margin: 0;
      display: flex; flex-direction: column; gap: 2px;
      border-bottom: 1px solid rgba(0,0,0,.06);
    }
    #mobile-drawer .drawer-sub a {
      display: block;
      padding: 10px 12px;
      font-family: var(--body);
      font-size: 14px;
      color: #2a2235;
      letter-spacing: .02em;
    }
    #mobile-drawer .drawer-sub a em {
      font-style: normal;
      color: var(--muted);
      font-size: 11px;
      letter-spacing: .14em;
      text-transform: uppercase;
      margin-left: 6px;
    }
    #mobile-drawer .drawer-sub a sup { font-size: 9px; }
    #mobile-drawer .drawer-cta {
      margin-top: auto;
      padding-top: 24px;
      display: flex; justify-content: center;
    }
    body.drawer-open { overflow: hidden; }

    /* ─── SCROLL ANIMATION HERO ─────────────────────────────────── */
    #scroll-hero { position: relative; height: 350vh; background: #ffffff; }
    #canvas-container {
      position: sticky; top: 0; width: 100%; height: 100vh; overflow: hidden;
      background: #ffffff;
    }
    #product-canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
    #canvas-left-grad {
      position: absolute; top: 0; left: 0; bottom: 0; width: 58%;
      background: linear-gradient(to right, rgba(255,255,255,1) 30%, rgba(255,255,255,0) 100%);
      pointer-events: none;
      transition: opacity .45s ease;
    }
    #canvas-bottom-grad {
      position: absolute; left: 0; right: 0; bottom: 0; height: 200px;
      background: linear-gradient(to top, rgba(255,255,255,.8) 0%, transparent 100%);
      pointer-events: none;
      transition: opacity .45s ease;
    }
    /* Hide the overlay-readability gradient when no scroll-text is visible
       so baked-in infographic labels on Frame 2 / Frame 3 stay legible. */
    #scroll-hero.no-overlay #canvas-left-grad,
    #scroll-hero.no-overlay #canvas-bottom-grad { opacity: 0; }
    #canvas-tint { position: absolute; inset: 0; pointer-events: none; transition: background .8s ease; }

    /* Chapter markers */
    #chapter-markers {
      position: fixed; right: 28px; top: 50%; transform: translateY(-50%);
      z-index: 200; display: flex; flex-direction: column; align-items: center;
      transition: opacity .4s ease;
    }
    #chapter-markers.hidden { opacity: 0; pointer-events: none; }
    .chapter-dot {
      width: 9px; height: 9px; border-radius: 50%;
      border: 1.5px solid rgba(26,18,37,.28); background: rgba(26,18,37,.04);
      position: relative; cursor: pointer;
      transition: border-color .3s, background .3s, transform .3s, box-shadow .3s;
    }
    .chapter-dot.active {
      border-color: var(--accent); background: var(--accent);
      transform: scale(1.35); box-shadow: 0 0 14px var(--accent-glow);
    }
    .chapter-dot::after {
      content: attr(data-label);
      position: absolute; right: 18px; top: 50%; transform: translateY(-50%);
      font-size: 9px; font-weight: 600; letter-spacing: .18em; text-transform: uppercase;
      color: rgba(26,18,37,.55); white-space: nowrap;
      opacity: 0; pointer-events: none; transition: opacity .3s;
    }
    .chapter-dot:hover::after, .chapter-dot.active::after { opacity: 1; color: var(--accent); }
    .chapter-line {
      width: 1px; height: 34px; background: rgba(26,18,37,.12); position: relative; overflow: hidden;
    }
    .chapter-fill {
      position: absolute; top: 0; left: 0; right: 0; height: 0%;
      background: var(--accent); transition: height .08s linear;
    }

    /* Scroll text overlays */
    .scroll-text {
      position: fixed; top: 0; left: 0; width: 100%; height: 100vh;
      display: flex; flex-direction: column; justify-content: center;
      padding: 80px 6vw 80px 10vw; z-index: 20; pointer-events: none;
      opacity: 0; transform: translateX(-24px);
      transition: opacity .55s ease, transform .55s ease, filter .55s ease;
      filter: blur(6px); max-width: 760px;
    }
    .scroll-text.visible { opacity: 1; transform: translateX(0); filter: blur(0); pointer-events: auto; }
    .st-overline {
      font-size: 10px; font-weight: 500; letter-spacing: .4em;
      text-transform: uppercase; color: var(--accent); margin-bottom: 16px;
    }
    .st-title {
      font-family: var(--heading); font-size: clamp(52px,7.5vw,110px);
      font-weight: 300; line-height: 1.05; color: #1a1225; margin-bottom: 22px;
    }
    .st-title em { font-style: italic; color: var(--accent); }
    .st-title .split-char {
      display: inline-block; opacity: 0; transform: translateY(30px);
      animation: char-in .55s forwards;
    }
    /* Word wrapper — keeps characters of a single word from breaking apart */
    .split-word { display: inline-block; white-space: nowrap; }
    .st-h2 {
      font-family: var(--heading); font-size: clamp(34px,4.5vw,64px);
      font-weight: 300; line-height: 1.15; color: #1a1225; margin-bottom: 26px;
    }
    .st-h2 em { font-style: italic; color: var(--accent); }
    .st-sub {
      font-size: clamp(15px,1.4vw,19px); font-weight: 300;
      color: rgba(26,18,37,.60); line-height: 1.75; margin-bottom: 28px; max-width: 480px;
    }
    .st-actions { display: flex; gap: 14px; flex-wrap: wrap; }
    .st-quote-mark {
      font-family: var(--heading); font-size: 80px; font-weight: 300;
      color: var(--accent); line-height: .7; margin-bottom: 10px;
    }
    .st-quote {
      font-family: var(--heading); font-size: clamp(28px,3.8vw,54px);
      font-weight: 300; font-style: italic; color: #1a1225;
      line-height: 1.3; margin-bottom: 22px;
    }
    .st-quote em { color: var(--accent); font-style: normal; }
    .st-divider { width: 48px; height: 1px; background: var(--accent); margin-bottom: 12px; }
    .st-attr { font-size: 11px; letter-spacing: .25em; text-transform: uppercase; color: rgba(26,18,37,.7); }
    .st-feature-list { list-style: none; display: flex; flex-direction: column; gap: 10px; }
    .st-feature-list li {
      font-size: 13px; font-weight: 300; color: rgba(26,18,37,.75);
      display: flex; align-items: center; gap: 12px;
      padding: 11px 15px; background: rgba(26,18,37,.04);
      border: 1px solid rgba(26,18,37,.08); border-radius: 10px;
      backdrop-filter: blur(8px);
    }
    .st-feat-icon { font-size: 16px; flex-shrink: 0; }
    .st-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .st-grid-cell {
      background: rgba(255,255,255,.55); border: 1px solid rgba(232,183,46,.15);
      border-radius: 14px; padding: 14px;
      backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    }
    .st-grid-cell span { font-size: 18px; display: block; margin-bottom: 5px; }
    .st-grid-cell strong { font-size: 12px; font-weight: 500; color: #1a1225; display: block; margin-bottom: 3px; }
    .st-grid-cell p { font-size: 11px; font-weight: 300; color: rgba(26,18,37,.5); line-height: 1.5; margin: 0; }

    /* Glass stat bar inside st-1 */
    .st-stat-bar {
      display: inline-flex;
      flex-wrap: nowrap;
      justify-content: center;
      gap: 0; margin-top: 32px;
      background: rgba(255,255,255,.85);
      backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(232,183,46,.45);
      border-radius: 16px;
      box-shadow:
        0 10px 30px rgba(138,106,30,.12),
        inset 0 1px 0 rgba(255,255,255,.75);
      overflow: visible;
      max-width: 100%;
    }
    .st-stat {
      flex: 1 1 auto;
      min-width: 0;
      padding: 12px 14px;
      text-align: center;
      border-right: 1px solid rgba(138,106,30,.18);
      display: flex; flex-direction: column;
      justify-content: center; align-items: center;
      gap: 6px;
      box-sizing: border-box;
    }
    .st-stat:last-child { border-right: none; }
    /* Inline wrapper — keeps the number and unit on the same line. */
    .st-stat-num {
      display: inline-flex !important;
      align-items: baseline;
      gap: 2px;
      white-space: nowrap !important;
      line-height: 1;
      justify-content: center;
    }
    .st-num {
      font-family: var(--heading); font-size: 24px; font-weight: 600;
      line-height: 1;
      letter-spacing: -.01em;
      white-space: nowrap !important;
      background: linear-gradient(135deg, #e8b72e 0%, #c99a2a 45%, #9c7818 100%);
      -webkit-background-clip: text; background-clip: text;
      -webkit-text-fill-color: transparent; color: transparent;
    }
    .st-unit {
      font-size: 15px; font-weight: 700; line-height: 1;
      white-space: nowrap !important;
      background: linear-gradient(135deg, #e8b72e 0%, #c99a2a 45%, #9c7818 100%);
      -webkit-background-clip: text; background-clip: text;
      -webkit-text-fill-color: transparent; color: transparent;
    }
    .st-label {
      font-size: 9px; font-weight: 700; letter-spacing: .12em;
      text-transform: uppercase; color: rgba(26,18,37,.78);
      line-height: 1.35;
      text-align: center;
      max-width: 11ch;
    }

    /* Scroll hint */
    #scroll-hint-anim {
      position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: 8px;
      z-index: 25; pointer-events: none;
      opacity: 0; animation: fade-up .8s 1.8s forwards;
    }
    #scroll-hint-anim span {
      font-size: 9px; letter-spacing: .3em; text-transform: uppercase;
      color: rgba(26,18,37,.4);
    }

    /* Buttons */
    .btn-primary {
      position: relative; overflow: hidden;
      padding: 13px 32px;
      background: linear-gradient(135deg, #8a6a1e 0%, #5e4a14 50%, #1a1225 100%);
      color: #ffffff; font-size: 11px; font-weight: 700; letter-spacing: .2em;
      text-transform: uppercase; border-radius: 40px;
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.25),
        inset 0 -1px 0 rgba(0,0,0,.35),
        0 6px 18px rgba(26,18,37,.3),
        0 0 0 1px rgba(26,18,37,.45);
      text-shadow: 0 1px 2px rgba(0,0,0,0.25);
      transition: transform .3s, box-shadow .3s, filter .3s; display: inline-block;
    }
    .btn-primary::before {
      content: ""; position: absolute; top: 0; left: -120%; width: 60%; height: 100%;
      background: linear-gradient(110deg, transparent 20%, rgba(255,255,255,.55) 50%, transparent 80%);
      transform: skewX(-18deg); pointer-events: none;
      transition: left .9s cubic-bezier(.2,.8,.2,1);
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      filter: brightness(1.10) saturate(1.1);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.35),
        inset 0 -1px 0 rgba(0,0,0,.4),
        0 16px 44px rgba(26,18,37,.4),
        0 0 0 1px rgba(26,18,37,.55);
    }
    .btn-primary:hover::before { left: 120%; }
    .btn-outline {
      padding: 13px 32px; border: 1px solid rgba(26,18,37,.25); color: rgba(26,18,37,.8);
      font-size: 11px; font-weight: 500; letter-spacing: .2em;
      text-transform: uppercase; border-radius: 40px;
      transition: border-color .3s, background .3s; display: inline-block;
    }
    .btn-outline:hover { border-color: rgba(26,18,37,.5); background: rgba(26,18,37,.05); }
    /* Light-section btn-outline override */
    .marquee-section ~ * .btn-outline,
    #products .btn-outline, #science .btn-outline, #stats .btn-outline,
    #about .btn-outline, #cta .btn-outline {
      border-color: rgba(26,18,37,.2); color: var(--warm-white);
    }

    .scroll-hint-line {
      width: 1px; height: 40px;
      background: linear-gradient(to bottom, rgba(26,18,37,.55), transparent);
      animation: line-pulse 1.8s ease-in-out infinite;
    }
    @keyframes line-pulse {
      0%,100% { opacity: .3; transform: scaleY(1); }
      50% { opacity: 1; transform: scaleY(1.2); }
    }

    /* Shared stat items (used in stats section) */
    .stat-item {
      flex: 1; padding: 20px 0; text-align: center;
      border-right: 1px solid rgba(0,0,0,.06);
    }
    .stat-item:last-child { border-right: none; }
    .stat-num { font-family: var(--heading); font-size: clamp(22px,2.5vw,32px); font-weight: 300; color: var(--warm-white); }
    .stat-num span { color: var(--accent); }
    .stat-label { font-size: 9px; font-weight: 500; letter-spacing: .25em; text-transform: uppercase; color: var(--muted); margin-top: 4px; }

    /* ─── MARQUEE ────────────────────────────────────────────────── */
    .marquee-section {
      padding: 20px 0;
      background: #1a1225;
      color: #f4f0ea;
      border-top: 1px solid rgba(0,0,0,.05);
      border-bottom: 1px solid rgba(0,0,0,.05);
      overflow: hidden;
    }
    .marquee-section .marquee-item { color: rgba(244,240,234,.75); }
    .marquee-section .marquee-item .dot { background: var(--accent); }
    .marquee-track {
      display: flex; gap: 0;
      animation: marquee-scroll 28s linear infinite;
      white-space: nowrap;
    }
    .marquee-section:hover .marquee-track,
    .marquee-section:focus-within .marquee-track { animation-play-state: paused; }
    .marquee-item {
      display: flex; align-items: center; gap: 40px;
      padding: 0 40px;
      font-size: 11px; font-weight: 600; letter-spacing: .3em;
      text-transform: uppercase; color: var(--warm-dim);
    }
    .marquee-item .dot { width: 4px; height: 4px; border-radius: 50%; background: var(--accent); }
    @keyframes marquee-scroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }

    /* ─── SECTION SHARED ─────────────────────────────────────────── */
    .section-header {
      text-align: center;
      margin-bottom: 72px;
    }
    .section-overline {
      font-size: 11px; font-weight: 700; letter-spacing: .32em;
      text-transform: uppercase; color: var(--accent-deep);
      margin-bottom: 16px;
    }
    .section-title {
      font-family: var(--heading);
      font-size: clamp(28px,4vw,52px);
      font-weight: 300;
      line-height: 1.15;
      color: var(--warm-white);
    }
    .section-title em { font-style: italic; color: var(--accent); }
    .section-body {
      font-size: clamp(14px,1.2vw,16px);
      font-weight: 300;
      color: var(--warm-dim);
      line-height: 1.8;
      max-width: 560px;
      margin: 20px auto 0;
    }
    /* Reveal — failsafe-first: starts hidden, but a CSS animation auto-
       reveals after 1.5s even if Motion One / theme.js fail to load.
       The JS observer still adds .visible for the smooth transition path. */
    @keyframes dc-reveal-failsafe {
      from { opacity: 0; transform: translateY(40px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .reveal {
      opacity: 0;
      transform: translateY(40px);
      animation: dc-reveal-failsafe .8s ease 1.5s forwards;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
      transition: opacity .8s ease, transform .8s ease;
      animation: none;
    }
    @media (prefers-reduced-motion: reduce) {
      .reveal { opacity: 1 !important; transform: none !important; animation: none !important; }
    }
    .reveal-delay-1 { transition-delay: .1s; }
    .reveal-delay-2 { transition-delay: .2s; }
    .reveal-delay-3 { transition-delay: .3s; }
    .reveal-delay-4 { transition-delay: .4s; }
    .reveal-delay-5 { transition-delay: .5s; }
    .reveal-delay-6 { transition-delay: .6s; }

    /* ─── PRODUCTS ───────────────────────────────────────────────── */
    #products {
      padding: 120px 48px;
      background: #ffffff;
      position: relative;
    }
    #products::before {
      content: '';
      position: absolute; top: 0; left: 50%; transform: translateX(-50%);
      width: 60%; height: 1px;
      background: linear-gradient(90deg, transparent, rgba(232,183,46,.35), transparent);
    }
    .products-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 24px;
      max-width: 1200px;
      margin: 0 auto;
    }
    .product-card {
      background: #ffffff;
      border: 1px solid rgba(0,0,0,.07);
      border-radius: 24px;
      overflow: hidden;
      position: relative;
      transition: transform .4s cubic-bezier(.2,.8,.2,1), border-color .4s, box-shadow .4s;
    }
    .product-card::before {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(232,183,46,.03) 0%, transparent 60%);
      pointer-events: none;
    }
    .product-card:hover {
      transform: translateY(-8px);
      border-color: rgba(232,183,46,.25);
      box-shadow: 0 24px 60px rgba(0,0,0,.10), 0 0 0 1px rgba(232,183,46,.08);
    }
    .product-image-wrap {
      height: 280px;
      background: linear-gradient(160deg, var(--blush) 0%, #fbf4de 100%);
      display: flex; align-items: center; justify-content: center;
      position: relative;
      overflow: hidden;
    }
    .product-image-wrap img {
      height: 220px; width: auto; object-fit: contain;
      transition: transform .6s cubic-bezier(.2,.8,.2,1);
      filter: drop-shadow(0 16px 32px rgba(0,0,0,.15));
    }
    .product-card:hover .product-image-wrap img {
      transform: scale(1.08) translateY(-6px);
    }
    .product-badge {
      position: absolute; top: 16px; right: 16px;
      font-size: 9px; font-weight: 600; letter-spacing: .2em;
      text-transform: uppercase;
      padding: 5px 12px; border-radius: 20px;
      background: var(--accent-soft);
      border: 1px solid rgba(232,205,135,.25);
      color: var(--accent);
    }
    /* Coming Soon pill — sits in the top-right of the image, ink-on-ivory,
       quieter than the Best Seller / New Formula gold pills so it reads
       as an editorial note rather than a promotional badge. */
    .product-soon-pill {
      position: absolute; top: 16px; right: 16px;
      font-size: 9px; font-weight: 600; letter-spacing: .2em;
      text-transform: uppercase;
      padding: 5px 12px; border-radius: 20px;
      background: rgba(26, 18, 37, 0.92);
      color: #fff;
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      z-index: 2;
    }
    .product-card.is-coming-soon .product-image-wrap img,
    .product-card.is-coming-soon .bottle-placeholder {
      filter: saturate(0.85);
      opacity: 0.92;
      transition: filter 360ms var(--dc-ease-soft, ease), opacity 360ms ease, transform 360ms ease;
    }
    .product-card.is-coming-soon:hover .product-image-wrap img,
    .product-card.is-coming-soon:hover .bottle-placeholder {
      filter: saturate(1);
      opacity: 1;
    }
    .product-shimmer {
      position: absolute; bottom: 0; left: 0; right: 0;
      height: 80px;
      background: linear-gradient(to top, #ffffff, transparent);
    }
    .product-info {
      padding: 28px 28px 32px;
    }
    .product-category {
      font-size: 10px; font-weight: 700; letter-spacing: .24em;
      text-transform: uppercase; color: var(--accent);
      margin-bottom: 10px;
    }
    .product-name {
      font-family: var(--heading);
      font-size: clamp(20px, 2vw, 26px);
      font-weight: 400;
      color: var(--warm-white);
      margin-bottom: 12px;
      letter-spacing: .02em;
    }
    .product-desc {
      font-size: 13px; font-weight: 300;
      color: var(--warm-dim); line-height: 1.7;
      margin-bottom: 20px;
    }
    .product-benefits {
      display: flex; flex-wrap: wrap; gap: 6px;
      margin-bottom: 24px;
    }
    .benefit-chip {
      font-size: 10px; font-weight: 400; letter-spacing: .05em;
      padding: 4px 12px; border-radius: 20px;
      background: rgba(0,0,0,.03);
      border: 1px solid rgba(0,0,0,.08);
      color: var(--warm-dim);
    }
    .product-cta {
      display: flex; align-items: center; justify-content: space-between;
    }
    .product-cta a,
    .product-cta .cta-label {
      font-size: 11px; font-weight: 500; letter-spacing: .18em;
      text-transform: uppercase; color: var(--accent);
      display: flex; align-items: center; gap: 8px;
      transition: gap .3s;
    }
    .product-cta a:hover { gap: 14px; }
    .product-cta a .arrow,
    .product-cta .cta-label .arrow {
      width: 28px; height: 28px; border-radius: 50%;
      border: 1px solid rgba(232,205,135,.3);
      display: flex; align-items: center; justify-content: center;
      font-size: 14px;
      transition: background .3s, border-color .3s;
    }
    .product-cta a:hover .arrow,
    .product-card:hover .product-cta .arrow {
      background: var(--accent);
      border-color: var(--accent);
      color: var(--ink);
    }
    .product-card:hover .product-cta .cta-label { gap: 14px; }
    /* Whole card clickable — card is an anchor */
    a.product-card { text-decoration: none; display: block; color: inherit; cursor: pointer; }

    /* Product-specific accent gradients */
    .product-card.collabloom .product-image-wrap {
      background: linear-gradient(160deg, #fde4ec 0%, #fef0f3 100%);
    }
    .product-card.collabloom .product-category,
    .product-card.collabloom .product-cta a,
    .product-card.collabloom .product-cta .cta-label { color: #e07a9e; }
    .product-card.collabloom .product-badge { background: rgba(224,122,158,.08); border-color: rgba(224,122,158,.22); color: #b05578; }
    .product-card.collabloom:hover { border-color: rgba(224,122,158,.28); }

    .product-card.skelecoll .product-image-wrap {
      background: linear-gradient(160deg, #f3e5d2 0%, #fbf4e6 100%);
    }
    .product-card.skelecoll .product-category,
    .product-card.skelecoll .product-cta a,
    .product-card.skelecoll .product-cta .cta-label { color: #b0845c; }
    .product-card.skelecoll .product-badge { background: rgba(176,132,92,.08); border-color: rgba(176,132,92,.22); color: #7d5a3e; }
    .product-card.skelecoll:hover { border-color: rgba(176,132,92,.28); }

    .product-card.metastable .product-image-wrap {
      background: linear-gradient(160deg, #eef8e8 0%, #f5faf0 100%);
    }
    .product-card.metastable .product-category,
    .product-card.metastable .product-cta a,
    .product-card.metastable .product-cta .cta-label { color: #4a8a2e; }
    .product-card.metastable .product-badge { background: rgba(74,138,46,.07); border-color: rgba(74,138,46,.2); color: #4a8a2e; }
    .product-card.metastable:hover { border-color: rgba(74,138,46,.25); }

    .product-card.collatrim .product-image-wrap {
      background: linear-gradient(160deg, #ebeed6 0%, #f4f6e5 100%);
    }
    .product-card.collatrim .product-category,
    .product-card.collatrim .product-cta a,
    .product-card.collatrim .product-cta .cta-label { color: #627636; }
    .product-card.collatrim .product-badge { background: rgba(143,168,82,.08); border-color: rgba(143,168,82,.22); color: #627636; }
    .product-card.collatrim:hover { border-color: rgba(143,168,82,.28); }

    /* Placeholder bottle SVG for products without images */
    .bottle-placeholder {
      width: 80px;
      opacity: .35;
    }

    /* ─── SCIENCE STRIP ──────────────────────────────────────────── */
    #science {
      padding: 100px 48px;
      background: linear-gradient(180deg, #fbf8f1 0%, #fdfaf4 100%);
      border-top: 1px solid rgba(0,0,0,.05);
      border-bottom: 1px solid rgba(0,0,0,.05);
    }
    .science-inner {
      max-width: 1200px; margin: 0 auto;
      display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;
    }
    .science-text .label {
      font-size: 10px; font-weight: 500; letter-spacing: .4em;
      text-transform: uppercase; color: var(--accent);
      margin-bottom: 20px;
    }
    .science-text h2 {
      font-family: var(--heading);
      font-size: clamp(28px, 3.5vw, 48px);
      font-weight: 300;
      line-height: 1.2;
      margin-bottom: 24px;
    }
    .science-text h2 em { font-style: italic; color: var(--accent); }
    .science-text p {
      font-size: 15px; font-weight: 300;
      color: var(--warm-dim); line-height: 1.85;
      margin-bottom: 16px;
    }
    .science-text .read-more {
      display: inline-flex; align-items: center; gap: 10px;
      font-size: 11px; font-weight: 500; letter-spacing: .2em;
      text-transform: uppercase; color: var(--accent);
      margin-top: 12px;
      transition: gap .3s;
    }
    .science-text .read-more:hover { gap: 16px; }
    .science-pillars {
      display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
    }
    .pillar-card {
      background: rgba(255,255,255,.7);
      border: 1px solid rgba(0,0,0,.06);
      border-radius: 18px;
      padding: 24px 20px;
      transition: background .3s, border-color .3s, box-shadow .3s;
    }
    .pillar-card:hover {
      background: #ffffff;
      border-color: rgba(232,183,46,.2);
      box-shadow: 0 8px 24px rgba(232,183,46,.08);
    }
    .pillar-icon {
      width: 40px; height: 40px; border-radius: 12px;
      background: var(--accent-soft);
      color: var(--accent);
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 14px;
    }
    .pillar-icon svg {
      width: 20px;
      height: 20px;
      stroke-width: 1.5;
    }
    .pillar-name {
      font-size: 13px; font-weight: 500;
      letter-spacing: .04em;
      color: var(--warm-white);
      margin-bottom: 8px;
    }
    .pillar-desc {
      font-size: 12px; font-weight: 300;
      color: var(--muted); line-height: 1.6;
    }

    /* ─── STATS ──────────────────────────────────────────────────── */
    #stats {
      padding: 100px 48px;
      background: #ffffff;
      border-top: 1px solid rgba(0,0,0,.05);
    }
    .stats-inner {
      max-width: 1000px; margin: 0 auto;
    }
    .stats-header { text-align: center; margin-bottom: 72px; }
    .stats-grid {
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px;
      border: 1px solid rgba(0,0,0,.07);
      border-radius: 24px; overflow: hidden;
      box-shadow: 0 4px 24px rgba(0,0,0,.05);
    }
    .stat-card {
      background: #ffffff;
      padding: 48px 24px;
      text-align: center;
      position: relative;
      transition: background .3s;
    }
    .stat-card:hover { background: var(--blush); }
    .stat-card::after {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; height: 2px;
      background: linear-gradient(90deg, transparent, var(--accent), transparent);
      opacity: 0;
      transition: opacity .3s;
    }
    .stat-card:hover::after { opacity: 1; }
    .stat-big {
      font-family: var(--heading);
      font-size: clamp(32px,4vw,56px);
      font-weight: 300;
      color: var(--warm-white);
      margin-bottom: 10px;
    }
    .stat-big .counter { color: var(--accent); }
    .stat-card .stat-label {
      font-size: 10px; font-weight: 500; letter-spacing: .25em;
      text-transform: uppercase; color: var(--muted);
      line-height: 1.5;
    }

    /* ─── ABOUT ──────────────────────────────────────────────────── */
    #about {
      padding: 120px 48px;
      background: linear-gradient(180deg, #fdfaf4 0%, #ffffff 100%);
      border-top: 1px solid rgba(0,0,0,.05);
    }
    .about-inner {
      max-width: 1200px; margin: 0 auto;
      display: grid; grid-template-columns: 1fr 1fr; gap: 96px; align-items: center;
    }
    .about-visual {
      position: relative;
    }
    .about-img-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 12px;
    }
    .about-img-cell {
      border-radius: 18px; overflow: hidden;
      background: var(--blush);
      border: 1px solid rgba(0,0,0,.05);
    }
    .about-img-cell.tall { grid-row: span 2; }
    .about-img-cell .inner {
      height: 100%; min-height: 180px;
      display: flex; align-items: center; justify-content: center;
      padding: 20px;
    }
    .about-img-cell img {
      width: 100%; height: 100%; object-fit: contain;
      border-radius: 12px;
    }
    .about-float-badge {
      position: absolute; bottom: -20px; right: -20px;
      background: #ffffff;
      border: 1px solid rgba(232,183,46,.2);
      border-radius: 18px;
      padding: 20px 24px;
      box-shadow: 0 8px 32px rgba(0,0,0,.08);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
    }
    .about-float-badge .num {
      font-family: var(--heading);
      font-size: 36px; font-weight: 300;
      color: var(--accent);
      line-height: 1;
    }
    .about-float-badge .txt {
      font-size: 10px; font-weight: 500;
      letter-spacing: .2em; text-transform: uppercase;
      color: var(--muted); margin-top: 4px;
    }
    .about-text .label {
      font-size: 10px; font-weight: 500; letter-spacing: .4em;
      text-transform: uppercase; color: var(--accent);
      margin-bottom: 20px;
    }
    .about-text h2 {
      font-family: var(--heading);
      font-size: clamp(28px, 3.5vw, 48px);
      font-weight: 300; line-height: 1.2;
      margin-bottom: 28px;
    }
    .about-text h2 em { font-style: italic; color: var(--accent); }
    .about-text p {
      font-size: 15px; font-weight: 300;
      color: var(--warm-dim); line-height: 1.85;
      margin-bottom: 16px;
    }
    .about-qualities {
      display: flex; flex-direction: column; gap: 12px;
      margin-top: 32px;
    }
    .quality-row {
      display: flex; align-items: center; gap: 14px;
      padding: 14px 18px;
      background: #ffffff;
      border: 1px solid rgba(0,0,0,.07);
      border-radius: 12px;
      transition: border-color .3s, background .3s, box-shadow .3s;
    }
    .quality-row:hover {
      border-color: rgba(232,183,46,.25);
      background: var(--blush);
      box-shadow: 0 4px 16px rgba(232,183,46,.07);
    }
    .quality-row .q-icon {
      width: 32px; height: 32px; border-radius: 10px;
      background: var(--accent-soft);
      display: flex; align-items: center; justify-content: center;
      font-size: 15px; flex-shrink: 0;
    }
    .quality-row .q-text {
