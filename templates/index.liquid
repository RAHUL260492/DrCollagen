    .testi-stars {
      color: var(--gold); font-size: 13px; letter-spacing: 2px;
      margin-bottom: 14px;
    }
    .testi-quote {
      font-size: 14px; font-weight: 300;
      color: var(--warm-dim); line-height: 1.75;
      font-style: italic;
      margin-bottom: 20px;
    }
    .testi-author {
      display: flex; align-items: center; gap: 12px;
    }
    .testi-avatar {
      width: 38px; height: 38px; border-radius: 50%;
      background: linear-gradient(135deg, var(--accent), var(--gold));
      display: flex; align-items: center; justify-content: center;
      font-size: 13px; font-weight: 600; color: var(--ink);
    }
    .testi-name { font-size: 13px; font-weight: 500; color: var(--warm-white); }
    .testi-role { font-size: 11px; font-weight: 300; color: var(--muted); }

    /* ─── INGREDIENTS FEATURE ────────────────────────────────────── */
    #ingredients {
      padding: 120px 48px;
      background: #ffffff;
      border-top: 1px solid rgba(0,0,0,.05);
    }
    .ingredients-inner {
      max-width: 1100px; margin: 0 auto;
    }
    .ingredients-grid {
      display: grid; grid-template-columns: repeat(3,1fr); gap: 24px;
      margin-top: 72px;
    }
    .ingr-card {
      background: #ffffff;
      border: 1px solid rgba(0,0,0,.07);
      border-radius: 20px;
      padding: 32px 28px;
      transition: transform .3s, border-color .3s, box-shadow .3s;
    }
    .ingr-card:hover {
      transform: translateY(-6px);
      border-color: rgba(232,183,46,.2);
      box-shadow: 0 20px 50px rgba(0,0,0,.08);
    }
    .ingr-num {
      font-family: var(--heading);
      font-size: 48px; font-weight: 300;
      color: rgba(232,183,46,.6);
      line-height: 1; margin-bottom: 16px;
    }
    .ingr-name {
      font-size: 14px; font-weight: 500;
      color: var(--warm-white);
      letter-spacing: .04em; margin-bottom: 10px;
    }
    .ingr-desc {
      font-size: 13px; font-weight: 300;
      color: var(--warm-dim); line-height: 1.7;
    }
    .ingr-tag {
      display: inline-block; margin-top: 14px;
      font-size: 9px; font-weight: 500; letter-spacing: .2em;
      text-transform: uppercase;
      padding: 4px 10px; border-radius: 20px;
      background: var(--accent-soft);
      border: 1px solid rgba(232,205,135,.2);
      color: var(--accent);
    }

    /* ─── CTA SECTION ────────────────────────────────────────────── */
    #cta {
      padding: 140px 48px;
      background: linear-gradient(180deg, #fdfaf4 0%, #faf3dc 100%);
      text-align: center;
      position: relative;
      overflow: hidden;
      border-top: 1px solid rgba(0,0,0,.05);
    }
    #cta::before {
      content: '';
      position: absolute; top: 50%; left: 50%;
      transform: translate(-50%,-50%);
      width: 600px; height: 600px; border-radius: 50%;
      background: radial-gradient(circle, rgba(232,183,46,.1) 0%, transparent 70%);
      pointer-events: none;
    }
    .cta-overline {
      font-size: 10px; font-weight: 500; letter-spacing: .4em;
      text-transform: uppercase; color: var(--accent);
      margin-bottom: 20px;
    }
    .cta-title {
      font-family: var(--heading);
      font-size: clamp(32px, 5vw, 68px);
      font-weight: 300; line-height: 1.15;
      margin-bottom: 24px;
    }
    .cta-title em { font-style: italic; color: var(--accent); }
    .cta-sub {
      font-size: clamp(14px, 1.3vw, 17px);
      font-weight: 300; color: var(--warm-dim);
      max-width: 480px; margin: 0 auto 48px;
      line-height: 1.75;
    }
    .cta-actions {
      display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;
    }

    /* ─── FOOTER ─────────────────────────────────────────────────── */
    footer {
      background: var(--warm-white);
      border-top: 1px solid rgba(255,255,255,.08);
      padding: 80px 48px 40px;
      color: var(--cream);
    }
    .footer-inner {
      max-width: 1200px; margin: 0 auto;
    }
    .footer-top {
      display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 60px;
      padding-bottom: 56px;
      border-bottom: 1px solid rgba(255,255,255,.1);
      margin-bottom: 32px;
    }
    .footer-brand .logo {
      font-family: var(--heading);
      font-size: 22px; font-weight: 600;
      letter-spacing: .08em; margin-bottom: 16px;
      color: #ffffff;
    }
    .footer-brand .logo span { color: var(--accent); }
    .footer-brand p {
      font-size: 13px; font-weight: 300;
      color: rgba(255,255,255,.55); line-height: 1.7; max-width: 260px;
    }
    .footer-social {
      display: flex; gap: 10px; margin-top: 20px;
    }
    .social-btn {
      width: 36px; height: 36px; border-radius: 50%;
      border: 1px solid rgba(255,255,255,.1);
      display: flex; align-items: center; justify-content: center;
      font-size: 14px; color: var(--muted);
      transition: border-color .3s, color .3s, background .3s;
    }
    .social-btn:hover {
      border-color: var(--accent);
      color: var(--accent);
      background: var(--accent-soft);
    }
    .footer-col h4 {
      font-size: 11px; font-weight: 600; letter-spacing: .25em;
      text-transform: uppercase; color: #ffffff;
      margin-bottom: 20px;
    }
    .footer-col ul { list-style: none; }
    .footer-col li { margin-bottom: 10px; }
    .footer-col a {
      font-size: 13px; font-weight: 300;
      color: rgba(255,255,255,.5);
      transition: color .3s;
    }
    .footer-col a:hover { color: #ffffff; }
    .footer-bottom {
      display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px;
    }
    .footer-legal {
      font-size: 11px; font-weight: 300; color: rgba(255,255,255,.4);
    }
    .footer-cert {
      display: flex; gap: 20px;
    }
    .cert-badge {
      font-size: 9px; font-weight: 500; letter-spacing: .15em;
      text-transform: uppercase;
      padding: 5px 12px; border-radius: 20px;
      border: 1px solid rgba(255,255,255,.15);
      color: rgba(255,255,255,.5);
    }

    /* ─── ANIMATIONS ─────────────────────────────────────────────── */
    @keyframes fade-up {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes char-in {
      from { opacity: 0; transform: translateY(30px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ─── NAV DARK-SECTION AWARENESS ─────────────────────────────── */
    nav.in-dark-section { color: #f4f0ea; }
    nav.in-dark-section .nav-logo { color: #f4f0ea; }
    nav.in-dark-section .nav-links a { color: rgba(244,240,234,.6); }
    nav.in-dark-section .nav-links a:hover { color: #f4f0ea; }
    nav.in-dark-section .nav-cta { border-color: rgba(244,240,234,.3); color: rgba(244,240,234,.8); }
    nav.in-dark-section .nav-cta:hover { background: var(--accent); color: #fff; border-color: var(--accent); }
    nav.scrolled.in-dark-section {
      background: rgba(14,11,20,.72);
      backdrop-filter: blur(18px) saturate(140%);
      -webkit-backdrop-filter: blur(18px) saturate(140%);
      border-bottom-color: rgba(255,255,255,.08);
    }
    nav.in-dark-section .nav-hamburger span {
      background: #f4f0ea;
    }
    nav.in-dark-section .nav-hamburger[aria-expanded="true"] span {
      background: var(--warm-white);
    }

    /* ─── RESPONSIVE ─────────────────────────────────────────────── */

    /* Tablet ≤ 900px */
    @media (max-width: 900px) {
      nav { padding: 20px 24px; }
      nav.scrolled { padding: 14px 24px; }
      .nav-links { display: none; }
      .nav-cta { display: none; }
      .nav-hamburger { display: block; }

      /* Light sections */
      #products, #science, #stats, #about, #ingredients, #cta, #testimonials { padding: 80px 24px; }
      .science-inner, .about-inner { grid-template-columns: 1fr; gap: 48px; }
      .stats-grid { grid-template-columns: repeat(2,1fr); }
      .ingredients-grid { grid-template-columns: 1fr 1fr; }
      .footer-top { grid-template-columns: 1fr 1fr; gap: 40px; }
      .about-float-badge { right: 0; bottom: -16px; }

      /* Scroll hero — reduce overlay width, stat bar wraps */
      .scroll-text { max-width: 520px; padding: 90px 5vw 60px; }
      .st-stat-bar { width: 100%; max-width: 440px; }
      .st-stat { flex: 1 1 50%; min-width: 50%; padding: 16px 10px; gap: 8px; }
      .st-stat:nth-child(2n) { border-right: none; }
      .st-stat:nth-child(-n+2) { border-bottom: 1px solid rgba(138,106,30,.18); }
      .st-num { font-size: 28px; }
      .st-unit { font-size: 17px; }
      .st-label { font-size: 10px; }
      .st-grid-cell p { font-size: 10px; }
      #chapter-markers { right: 14px; }
      .chapter-dot::after { display: none; }
    }

    /* Mobile ≤ 600px */
    @media (max-width: 600px) {
      /* Hide cursor, set normal cursor */
      #cursor-dot, #cursor-ring { display: none; }
      body { cursor: auto; }
      button, a { cursor: pointer; }

      /* Light sections */
      .products-grid { grid-template-columns: 1fr; }
      .science-pillars { grid-template-columns: 1fr; }
      .ingredients-grid { grid-template-columns: 1fr; }
      .stats-grid { grid-template-columns: 1fr 1fr; }
      .footer-top { grid-template-columns: 1fr; }

      /* Scroll hero — full-width overlay, vertically centered text */
      #scroll-hero { height: 320vh; }
      .scroll-text {
        max-width: 100%; padding: 40px 24px 120px;   /* extra bottom padding so CTAs clear hero image */
        justify-content: center;
        top: 0; bottom: auto; height: 100vh;
      }
      /* Near-opaque wash so headline and CTAs stay legible over the hero canvas. */
      #canvas-left-grad { width: 100%;
        background: linear-gradient(to bottom, rgba(255,255,255,.92) 0%, rgba(255,255,255,.80) 45%, rgba(255,255,255,.90) 100%);
        top: 0; bottom: 0; height: 100%;
      }
      #product-canvas { opacity: 0.55; }   /* dim the hero canvas behind text */
      #canvas-bottom-grad { display: none; }

      /* Stat bar stacks as 2x2 grid */
      .st-stat-bar { display: grid; grid-template-columns: 1fr 1fr; width: 100%; max-width: 100%; }
      .st-stat { border-right: none; border-bottom: 1px solid rgba(138,106,30,.14); padding: 12px 14px; }
      .st-stat:nth-child(odd) { border-right: 1px solid rgba(138,106,30,.14); }
      .st-stat:nth-last-child(-n+2) { border-bottom: none; }

      /* Grid sections single col on mobile */
      .st-grid { grid-template-columns: 1fr; }

      /* Title sizes — larger on mobile */
      .st-title { font-size: clamp(40px, 11vw, 68px); }
      .st-h2 { font-size: clamp(30px, 8.5vw, 50px); }
      .st-quote { font-size: clamp(26px, 7vw, 40px); }
      .st-quote-mark { font-size: 64px; }
      .st-sub { font-size: clamp(14px, 3.8vw, 17px); }

      /* Feature list items smaller */
      .st-feature-list li { font-size: 12px; padding: 10px 12px; }

      /* Chapter markers — hide on mobile */
      #chapter-markers { display: none; }

      /* Scroll hint position */
      #scroll-hint-anim { bottom: 16px; }

      /* Buttons — slightly smaller on mobile */
      .btn-primary, .btn-outline { padding: 12px 24px; font-size: 10px; }

      /* Performance: reduce particles, hide grain */
      #film-grain { display: none; }
    }

    /* Small mobile ≤ 380px */
    @media (max-width: 380px) {
      .scroll-text { padding: 40px 16px 100px; }
      .st-title { font-size: 28px; }
      .st-h2 { font-size: 22px; }
      .st-stat-bar { grid-template-columns: 1fr 1fr; }
      .st-num { font-size: 28px; }
      .st-unit { font-size: 17px; }
      .st-label { font-size: 9px; letter-spacing: .14em; }
      .nav-logo { font-size: 17px; }
      .nav-cta { padding: 8px 16px; font-size: 10px; }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
    }
  
    /* Logo lockup: Dr Collagen + "Formulated by Doctors" subtitle */
    .nav-logo {
      display: inline-flex;
      flex-direction: column;
      align-items: flex-start;
