    .testi-card {
      width: 340px; flex-shrink: 0;
      background: #ffffff;
      border: 1px solid rgba(0,0,0,.07);
      border-radius: 20px;
      padding: 28px;
      box-shadow: 0 4px 20px rgba(0,0,0,.04);
