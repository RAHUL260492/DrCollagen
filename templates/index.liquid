<script>
// ═══ MOBILE HAMBURGER DRAWER ════════════════════════════════════════
(function() {
  const btn = document.getElementById('nav-hamburger');
  const drawer = document.getElementById('mobile-drawer');
  if (!btn || !drawer) return;
  function setOpen(open) {
    btn.setAttribute('aria-expanded', String(open));
    btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    drawer.classList.toggle('open', open);
    drawer.setAttribute('aria-hidden', String(!open));
    document.body.classList.toggle('drawer-open', open);
  }
  btn.addEventListener('click', () => {
    setOpen(!drawer.classList.contains('open'));
  });
  // Close on link tap inside drawer
  drawer.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => setOpen(false));
  });
  // Close on Esc
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && drawer.classList.contains('open')) {
      setOpen(false);
      btn.focus();
    }
  });
})();

// ═══ DROPDOWN ARIA STATE ═══════════════════════════════════════════
(function() {
  document.querySelectorAll('.has-dropdown').forEach(li => {
    const trigger = li.querySelector('a');
    if (!trigger) return;
    function setExpanded(v) { trigger.setAttribute('aria-expanded', String(v)); }
    li.addEventListener('mouseenter', () => setExpanded(true));
    li.addEventListener('mouseleave', () => setExpanded(false));
    li.addEventListener('focusin',   () => setExpanded(true));
    li.addEventListener('focusout',  () => setExpanded(false));
  });
})();

// ═══ CUSTOM CURSOR (WITH MOTION SPRING PHYSICS) ═════════════════════
(function() {
  const dot = document.getElementById('cursor-dot');
  const ring = document.getElementById('cursor-ring');
  if (!dot || !ring || window.innerWidth < 600) return;

  const { animate } = Motion;
  let mx = -100, my = -100;

  document.addEventListener('mousemove', e => {
    mx = e.clientX;
    my = e.clientY;
    dot.style.transform = `translate3d(${mx}px, ${my}px, 0) translate(-50%, -50%)`;
    
    animate(ring, {
      transform: [`translate3d(${mx}px, ${my}px, 0) translate(-50%, -50%)`]
    }, {
      type: "spring",
      stiffness: 300,
      damping: 25,
      mass: 0.5
    });
  });

  document.querySelectorAll('a, button, .product-card, .pillar-card, .ingr-card').forEach(el => {
    el.addEventListener('mouseenter', () => document.body.classList.add('hovering'));
    el.addEventListener('mouseleave', () => document.body.classList.remove('hovering'));
  });
})();

// ═══ PARTICLES ══════════════════════════════════════════════════════
(function() {
  const canvas = document.getElementById('particles-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let W, H, particles = [];

  function resize() {
    W = canvas.width  = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  function rand(min, max) { return Math.random() * (max - min) + min; }

  // Blue / gold particles
  for (let i = 0; i < 45; i++) {
    particles.push({
      x: rand(0, W), y: rand(0, H),
      r: rand(0.3, 1.6),
      vx: rand(-0.15, 0.15),
      vy: rand(-0.2, -0.05),
      alpha: rand(0.04, 0.28),
      hue: rand(0, 1) > 0.6 ? 'rgba(232,205,135,' : 'rgba(200,160,96,'
    });
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);
    particles.forEach(p => {
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = p.hue + p.alpha + ')';
      ctx.fill();
      p.x += p.vx; p.y += p.vy;
      if (p.y < -4)  p.y = H + 4;
      if (p.x < -4)  p.x = W + 4;
      if (p.x > W+4) p.x = -4;
    });
    requestAnimationFrame(draw);
  }
  draw();
})();

// ═══ LOADER — controlled by frame animation, stub here ══════════════
(function() {
  // Loader hide is triggered by frame animation JS once first frame loads
  // Just ensure loader stays visible initially
})();

// ═══ NAV SCROLL + HERO-ZONE AWARENESS ═══════════════════════════════
(function() {
  const nav     = document.getElementById('navbar');
  const hero    = document.getElementById('scroll-hero');
  const markers = document.getElementById('chapter-markers');
  const darkSections = document.querySelectorAll('.marquee-section, footer');

  function update() {
    const scrolled = window.scrollY > 80;
    nav.classList.toggle('scrolled', scrolled);

    // Bounding-box collision detection for dark sections
    const navRect = nav.getBoundingClientRect();
    let inDark = false;
    for (const section of darkSections) {
      const rect = section.getBoundingClientRect();
      if (rect.top <= navRect.bottom && rect.bottom >= navRect.top) {
        inDark = true;
        break;
      }
    }
    nav.classList.toggle('in-dark-section', inDark);

    // Are we inside the sticky hero zone? (hero bottom still below viewport top)
    if (hero) {
      const heroRect = hero.getBoundingClientRect();
      const inHero   = heroRect.top <= 0 && heroRect.bottom > window.innerHeight * 0.25;

      // Chapter markers only visible while inside the hero
      if (markers) markers.classList.toggle('hidden', !inHero);

      // Hide scroll-text overlays once outside the hero zone
      if (!inHero) {
        document.querySelectorAll('.scroll-text').forEach(el => el.classList.remove('visible'));
      }

      // Scroll hint only while at very top of hero
      const scrollHint = document.getElementById('scroll-hint-anim');
      if (scrollHint) {
        scrollHint.style.opacity = (inHero && window.scrollY < window.innerHeight * 0.4) ? '' : '0';
      }
    }
  }
  window.addEventListener('scroll', update, { passive: true });
  window.addEventListener('resize', update);
  update();
})();

// ═══ LETTER SPLIT — handled inside frame animation init ─────────────
// (no-op here; executed after first frame loads)

// ═══ SCROLL REVEAL (WITH MOTION SPRING PHYSICS) ═════════════════════
(function() {
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.querySelectorAll('.reveal').forEach(el => el.classList.add('visible'));
    return;
  }
  const { inView, animate } = Motion;
  inView(".reveal", ({ target }) => {
    let delay = 0;
    for (let i = 1; i <= 6; i++) {
      if (target.classList.contains(`reveal-delay-${i}`)) {
        delay = i * 0.12;
        break;
      }
    }
    animate(target, 
      { opacity: [0, 1], y: [40, 0] }, 
      { 
        delay, 
        duration: 0.85, 
        easing: [0.16, 1, 0.3, 1] // spring physics curve
      }
    );
  });
})();

// ═══ COUNTER ANIMATION ──────────────────────────────────────────────
(function() {
  const counters = document.querySelectorAll('.counter');
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      const el = e.target;
      const target = parseInt(el.dataset.target || '0', 10);
      const duration = 1500;
      const start = performance.now();
      function step(now) {
        const t = Math.min((now - start) / duration, 1);
        // ease-out cubic
        const eased = 1 - Math.pow(1 - t, 3);
        el.textContent = Math.round(eased * target).toLocaleString();
        if (t < 1) requestAnimationFrame(step);
        else el.textContent = target.toLocaleString();
      }
      requestAnimationFrame(step);
      io.unobserve(el);
    });
  }, { threshold: 0.5 });
  counters.forEach(c => io.observe(c));
})();

// ═══ SMOOTH HOVER GLOW ON PRODUCT CARDS ─────────────────────────────
(function() {
  document.querySelectorAll('.product-card').forEach(card => {
    card.addEventListener('mousemove', e => {
      const rect = card.getBoundingClientRect();
      const x = ((e.clientX - rect.left) / rect.width  * 100).toFixed(1);
      const y = ((e.clientY - rect.top)  / rect.height * 100).toFixed(1);
      card.style.background = `radial-gradient(circle at ${x}% ${y}%, rgba(232,183,46,.05) 0%, transparent 55%), #ffffff`;
    });
    card.addEventListener('mouseleave', () => {
      card.style.background = '';
    });
  });
})();

// ═══ SCROLL-DRIVEN FRAME ANIMATION ──────────────────────────────────
(function() {
  const FRAME_COUNT = 3;
  const FRAME_URLS  = [
    {{ 'hero-frame-0001.webp' | asset_url | json }},
    {{ 'hero-frame-0002.webp' | asset_url | json }},
    {{ 'hero-frame-0003.webp' | asset_url | json }}
  ];
  const LERP_FACTOR = 0.09;

  // ── Dwell engine ──────────────────────────────────────────────────
  // 3 frames → 3 long dwells (each lets the baked-in infographic read)
  const DWELL_CENTERS = [0.10, 0.50, 0.90];
  const DWELL_WIDTH   = 0.090;
  const DWELL_PEAK    = 4.2;
  const REMAP_N       = 2000;

  function buildLUT() {
    const lut = new Float32Array(REMAP_N + 1);
    let sum = 0;
    for (let i = 0; i <= REMAP_N; i++) {
      const t = i / REMAP_N;
      let density = 1;
      for (const c of DWELL_CENTERS) {
        const d = (t - c) / DWELL_WIDTH;
        density += (DWELL_PEAK - 1) * Math.exp(-0.5 * d * d);
      }
      sum += density;
      lut[i] = sum;
    }
    const max = lut[REMAP_N];
    for (let i = 0; i <= REMAP_N; i++) lut[i] /= max;
    return lut;
  }
  const lut = buildLUT();

  function remapProgress(raw) {
    let lo = 0, hi = REMAP_N;
    while (lo < hi) {
      const mid = (lo + hi) >> 1;
      if (lut[mid] < raw) lo = mid + 1; else hi = mid;
    }
    return lo / REMAP_N;
  }

  // ── Canvas & elements ─────────────────────────────────────────────
  const section   = document.getElementById('scroll-hero');
  const container = document.getElementById('canvas-container');
  const canvas    = document.getElementById('product-canvas');
  const ctx       = canvas.getContext('2d');
  const tint      = document.getElementById('canvas-tint');
  const chapterMarkers = document.getElementById('chapter-markers');
  const dots       = chapterMarkers ? chapterMarkers.querySelectorAll('.chapter-dot') : [];
  const lines      = chapterMarkers ? chapterMarkers.querySelectorAll('.chapter-line') : [];
  const fills      = chapterMarkers ? chapterMarkers.querySelectorAll('.chapter-fill') : [];
  const scrollHint = document.getElementById('scroll-hint-anim');
  const scrollTexts = document.querySelectorAll('.scroll-text');

  // ── Resize canvas ─────────────────────────────────────────────────
  function resizeCanvas() {
    canvas.width  = window.innerWidth  * Math.min(window.devicePixelRatio, 2);
    canvas.height = window.innerHeight * Math.min(window.devicePixelRatio, 2);
    canvas.style.width  = '100%';
    canvas.style.height = '100%';
    if (frames[currentFrameIdx]) drawFrame(currentFrameIdx);
  }
  window.addEventListener('resize', resizeCanvas);

  // ── Frame storage ─────────────────────────────────────────────────
  const frames = new Array(FRAME_COUNT).fill(null);
  let loadedCount = 0;
  let currentFrameIdx = 0;
  let targetFrameIdx  = 0;
  let animStarted = false;

  function padNum(n) { return String(n).padStart(4, '0'); }

  function loadFrame(i, cb) {
    if (frames[i]) { if (cb) cb(); return; }
    const img = new Image();
    img.onload = () => {
      frames[i] = img;
      loadedCount++;
      updateLoader();
      if (cb) cb();
    };
    img.onerror = () => { loadedCount++; updateLoader(); if (cb) cb(); };
    img.src = FRAME_URLS[i];
  }

  function updateLoader() {
    const pct = Math.round((loadedCount / FRAME_COUNT) * 100);
    const fill = document.getElementById('loader-fill');
    const pctEl = document.getElementById('loader-pct');
    if (fill)  fill.style.width = pct + '%';
    if (pctEl) pctEl.textContent = pct + '%';
    if (loadedCount >= FRAME_COUNT && !animStarted) startAnimation();
  }

  // Critical frames first (evenly spaced), then rest
  const CRITICAL_COUNT = FRAME_COUNT;
  let criticalLoaded = 0;
  function loadCritical() {
    for (let i = 0; i < CRITICAL_COUNT; i++) {
      const idx = Math.round((i / (CRITICAL_COUNT - 1)) * (FRAME_COUNT - 1));
      loadFrame(idx, () => {
        criticalLoaded++;
        if (criticalLoaded === 1) {
          // Show first frame immediately
          resizeCanvas();
          drawFrame(0);
          hideLoader();
        }
        if (criticalLoaded >= CRITICAL_COUNT) loadRemaining();
      });
    }
  }

  function loadRemaining() {
    for (let i = 0; i < FRAME_COUNT; i++) {
      if (!frames[i]) loadFrame(i);
    }
  }

  function hideLoader() {
    const loader = document.getElementById('loader');
    if (loader) {
      loader.classList.add('fade-out');
      setTimeout(() => loader.remove(), 700);
    }
  }

  // ── Draw ──────────────────────────────────────────────────────────
  function drawFrame(idx) {
    idx = Math.max(0, Math.min(FRAME_COUNT - 1, Math.round(idx)));
    // Find nearest loaded frame
    let img = frames[idx];
    if (!img) {
      for (let offset = 1; offset < FRAME_COUNT; offset++) {
        if (frames[idx - offset]) { img = frames[idx - offset]; break; }
        if (frames[idx + offset]) { img = frames[idx + offset]; break; }
      }
    }
    if (!img) return;

    const cw = canvas.width, ch = canvas.height;
    const iw = img.naturalWidth, ih = img.naturalHeight;

    // Contain-fit: show full bottle, fill background on sides
    const scale = Math.min(cw / iw, ch / ih);
    const dw = iw * scale, dh = ih * scale;
    const dx = (cw - dw) / 2;
    const dy = window.innerWidth <= 600 ? (ch - dh) * 0.95 : (ch - dh) / 2;

    ctx.clearRect(0, 0, cw, ch);
    ctx.drawImage(img, dx, dy, dw, dh);
    currentFrameIdx = idx;
  }

  // ── Scroll progress ───────────────────────────────────────────────
  function getScrollProgress() {
    if (!section) return 0;
    const rect = section.getBoundingClientRect();
    return Math.max(0, Math.min(1, -rect.top / (rect.height - window.innerHeight)));
  }

  // ── Scroll text visibility ────────────────────────────────────────
  let currentSection = -1;
  function updateScrollTexts(raw) {
    let newSection = -1;
    scrollTexts.forEach((el, i) => {
      const showAt = parseFloat(el.dataset.showAt || 0);
      const hideAt = parseFloat(el.dataset.hideAt || 1);
      const visible = raw >= showAt && raw < hideAt;
      el.classList.toggle('visible', visible);
      if (visible) newSection = i;
    });

    // Toggle the readability-gradient fade when no overlay is on screen
    if (section) section.classList.toggle('no-overlay', newSection === -1);

    // Chapter markers — driven by scroll progress bands (not overlay visibility)
    // so dots stay active during frame-dwell zones when overlays are hidden.
    // Bands match the 3 dwell centers: Frame 1 (0.10), Frame 2 (0.50), Frame 3 (0.90).
    const BAND_EDGES = [0.30, 0.70]; // band 0: 0-0.30, band 1: 0.30-0.70, band 2: 0.70-1
    dots.forEach((dot) => dot.classList.remove('active'));
    fills.forEach(f => f.style.height = '0%');

    let activeDot = 0;
    if (raw >= BAND_EDGES[1]) activeDot = 2;
    else if (raw >= BAND_EDGES[0]) activeDot = 1;
    if (dots[activeDot]) dots[activeDot].classList.add('active');

    // Fill lines between chapter dots based on progress within each band
    const bandStarts = [0, BAND_EDGES[0], BAND_EDGES[1]];
    const bandEnds   = [BAND_EDGES[0], BAND_EDGES[1], 1];
    for (let i = 0; i < fills.length; i++) {
      const s0 = bandStarts[i], s1 = bandEnds[i];
      if (raw >= s1) fills[i].style.height = '100%';
      else if (raw >= s0) fills[i].style.height = (((raw - s0) / (s1 - s0)) * 100) + '%';
    }

    // Hide chapter markers and scroll hint after animation zone
    if (chapterMarkers) chapterMarkers.classList.toggle('hidden', raw >= 0.99);
    if (scrollHint) scrollHint.style.opacity = raw > 0.05 ? '0' : '';
  }

  // ── Tint per section ──────────────────────────────────────────────
  const TINTS = [
    'transparent',
    'rgba(232,183,46,.04)',
    'rgba(100,120,200,.05)',
    'rgba(80,160,120,.04)',
    'rgba(180,140,60,.04)',
  ];
  let currentTint = 0;
  function updateTint(raw) {
    const idx = Math.min(TINTS.length - 1, Math.floor(raw * TINTS.length));
    if (idx !== currentTint) {
      currentTint = idx;
      if (tint) tint.style.background = TINTS[idx];
    }
  }

  // ── Animation loop ────────────────────────────────────────────────
  let rafTarget = 0;
  let rafCurrent = 0;

  function startAnimation() {
    animStarted = true;

    // Letter split for first section title — splits TEXT NODES into word groups
    // (each word is inline-block so it won't break mid-word), then wraps each
    // character in an animated span. Child elements like <em> are left intact
    // so their own styling (e.g. metallic-gold background-clip:text) keeps working.
    document.querySelectorAll('[data-split]').forEach(el => {
      Array.from(el.childNodes).forEach(node => {
        if (node.nodeType !== 3) return; // skip element nodes (like <em>)
        const frag = document.createDocumentFragment();
        node.textContent.split(/(\s+)/).forEach(segment => {
          if (!segment) return;
          if (/^\s+$/.test(segment)) {
            frag.appendChild(document.createTextNode(segment));
            return;
          }
          const wordSpan = document.createElement('span');
          wordSpan.className = 'split-word';
          for (const ch of segment) {
            const charSpan = document.createElement('span');
            charSpan.className = 'split-char';
            charSpan.style.animationDelay =
              (Math.random() * 0.4 + 0.3).toFixed(2) + 's';
            charSpan.textContent = ch;
            wordSpan.appendChild(charSpan);
          }
          frag.appendChild(wordSpan);
        });
        node.parentNode.replaceChild(frag, node);
      });
    });

    function animate() {
      const raw     = getScrollProgress();
      const remapped = remapProgress(raw);
      rafTarget = remapped * (FRAME_COUNT - 1);
      rafCurrent += (rafTarget - rafCurrent) * LERP_FACTOR;
      drawFrame(Math.round(rafCurrent));
      updateScrollTexts(raw);
      updateTint(raw);
      requestAnimationFrame(animate);
    }
    animate();
  }

  // ── Init ──────────────────────────────────────────────────────────
  // Override the basic loader to tie into frame loading
  const loaderEl = document.getElementById('loader');
  if (loaderEl) {
    // Keep loader until first frame loaded (handled in loadCritical)
    // Clear the auto-fade loader set earlier
    const existingFill = document.getElementById('loader-fill');
    if (existingFill) existingFill.style.width = '0%';
  }

  loadCritical();

  // Fallback: if the first hero frame hasn't loaded within 4 seconds
  // (CDN miss, slow network, etc.), force the loader to fade and let
  // the visitor through to the page rather than stranding them.
  setTimeout(function () {
    var loader = document.getElementById('loader');
    if (loader && !loader.classList.contains('fade-out')) {
      hideLoader();
    }
  }, 4000);
})();

/* ─── Typewriter heading (doctor strip) ──────────────────────────────
   Types out each segment of [data-typewriter] elements character by
   character when scrolled into view. Honors prefers-reduced-motion. */
(function () {
  var nodes = document.querySelectorAll('[data-typewriter]');
  if (!nodes.length) return;

  var REDUCED = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function fillImmediately(heading) {
    heading.querySelectorAll('.tw-segment').forEach(function (seg) {
      seg.textContent = seg.dataset.text;
    });
  }

  function type(heading) {
    var segs = Array.prototype.slice.call(heading.querySelectorAll('.tw-segment'));
    var i = 0, j = 0;
    function step() {
      if (i >= segs.length) return;
      var s = segs[i];
      var t = s.dataset.text;
      if (j < t.length) {
        s.textContent = t.substring(0, ++j);
        setTimeout(step, 45 + Math.random() * 35);
      } else {
        i++; j = 0;
        setTimeout(step, 90);
      }
    }
    step();
  }

  if (REDUCED) {
    nodes.forEach(fillImmediately);
    return;
  }

  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        type(entry.target);
        io.unobserve(entry.target);
      }
    });
  }, { threshold: 0.45 });

  nodes.forEach(function (h) { io.observe(h); });
})();
</script>