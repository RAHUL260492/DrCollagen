      .doc-strip-icon { width: 72px; height: 72px; font-size: 38px; }
      .doc-strip-lede { font-size: 15px; }
    }

  
    /* Typewriter heading — types out character-by-character on scroll-in */
    .doc-strip-heading[data-typewriter] {
      min-height: 1.2em;
      color: #1a1225;
    }
    /* Regular text segments: explicit black, kill any inherited gradient
       so the heading is never tinted by a global em/heading rule. */
    .doc-strip-heading[data-typewriter] .tw-segment {
      display: inline;
      color: #1a1225 !important;
      -webkit-text-fill-color: #1a1225 !important;
      background: none !important;
      -webkit-background-clip: initial !important;
              background-clip: initial !important;
      font-style: normal;
    }
    /* The single emphasized word ("doctors"): accent gold/walnut, italic. */
    .doc-strip-heading[data-typewriter] em.tw-segment {
      color: var(--accent-deep, #b8903a) !important;
      -webkit-text-fill-color: var(--accent-deep, #b8903a) !important;
      font-style: italic;
    }
    .tw-caret {
      display: inline-block;
      width: 0.45ch;
