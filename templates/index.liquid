    /* ─── FORMULATED BY DOCTORS strip ──────────────────────────────── */
    #doctor-strip {
      background: linear-gradient(135deg, #faf6e8 0%, #f5f0d8 100%);
      border-top: 1px solid rgba(184, 144, 58, .2);
      border-bottom: 1px solid rgba(184, 144, 58, .2);
