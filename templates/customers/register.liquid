<section class="dc-account-card">
  <h1 class="dc-account-title">Create an account</h1>

  {% form 'create_customer' %}
    {{ form.errors | default_errors }}

    <label class="dc-account-label" for="register-first">First name</label>
    <input class="dc-account-input" type="text" id="register-first" name="customer[first_name]" autocomplete="given-name">

    <label class="dc-account-label" for="register-last">Last name</label>
    <input class="dc-account-input" type="text" id="register-last" name="customer[last_name]" autocomplete="family-name">

    <label class="dc-account-label" for="register-email">Email</label>
    <input class="dc-account-input" type="email" id="register-email" name="customer[email]" required autocomplete="email">

    <label class="dc-account-label" for="register-password">Password</label>
    <input class="dc-account-input" type="password" id="register-password" name="customer[password]" required autocomplete="new-password">

    <button class="dc-btn dc-btn--primary dc-btn--block" type="submit">Create account</button>
  {% endform %}

  <p class="dc-account-divider">
    Already have an account? <a class="dc-account-link" href="{{ routes.account_login_url }}">Sign in</a>
  </p>
</section>
