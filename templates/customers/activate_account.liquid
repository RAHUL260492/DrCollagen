<section class="dc-account-card">
  <h1 class="dc-account-title">Activate account</h1>
  <p class="dc-account-lede">Create a password to activate your account.</p>

  {% form 'activate_customer_password' %}
    {{ form.errors | default_errors }}

    <label class="dc-account-label" for="activate-password">Password</label>
    <input class="dc-account-input" type="password" id="activate-password" name="customer[password]" required autocomplete="new-password">

    <label class="dc-account-label" for="activate-password-confirm">Confirm password</label>
    <input class="dc-account-input" type="password" id="activate-password-confirm" name="customer[password_confirmation]" required autocomplete="new-password">

    <button class="dc-btn dc-btn--primary dc-btn--block" type="submit">Activate</button>
  {% endform %}
</section>
