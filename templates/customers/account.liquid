<section class="dc-account-page">
  <header class="dc-account-page__header">
    <h1 class="dc-account-page__title">Hi, {{ customer.first_name | default: 'there' }}</h1>
    <p class="dc-account-page__sub">
      <a class="dc-account-eyebrow" href="{{ routes.account_logout_url }}">Sign out</a>
    </p>
  </header>

  <h2 class="dc-account-section-title">Order history</h2>
  {% if customer.orders.size > 0 %}
    <div class="dc-account-table-wrap">
      <table class="dc-account-table">
        <thead>
          <tr>
            <th>Order</th>
            <th>Date</th>
            <th>Status</th>
            <th class="dc-account-table__right">Total</th>
          </tr>
        </thead>
        <tbody>
          {% for order in customer.orders %}
            <tr>
              <td><a class="dc-account-link" href="{{ order.customer_url }}">{{ order.name }}</a></td>
              <td>{{ order.created_at | date: '%b %d, %Y' }}</td>
              <td>{{ order.financial_status_label }}</td>
              <td class="dc-account-table__right">{{ order.total_price | money }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% else %}
    <p class="dc-account-body">You haven't placed any orders yet.</p>
  {% endif %}

  <h2 class="dc-account-section-title">Default address</h2>
  {% if customer.default_address %}
    <address class="dc-account-address">
      {{ customer.default_address | format_address }}
    </address>
    <p class="dc-account-foot">
      <a class="dc-account-eyebrow" href="{{ routes.account_addresses_url }}">Manage addresses &rarr;</a>
    </p>
  {% else %}
    <p class="dc-account-body">No address on file. <a class="dc-account-link" href="{{ routes.account_addresses_url }}">Add one &rarr;</a></p>
  {% endif %}
</section>
