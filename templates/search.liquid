{% comment %}Search results template — luxury rebuild{% endcomment %}

<style>
  .search-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: var(--space-6) clamp(20px, 4vw, 48px);
    font-family: var(--dc-body);
    color: var(--dc-fg);
  }
  .search-eyebrow {
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--dc-accent);
    font-weight: 500;
    margin-bottom: 12px;
  }
  .search-page h1 {
    font-family: var(--dc-heading);
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 400;
    margin: 0 0 32px;
    color: var(--dc-ink);
    letter-spacing: -0.015em;
  }
  .search-form {
    display: flex;
    gap: 8px;
    margin-bottom: 56px;
    max-width: 640px;
  }
  .search-form input {
    flex: 1;
    padding: 16px 22px;
    border: 1px solid var(--dc-line-strong);
    border-radius: var(--dc-radius-pill);
    background: var(--dc-bg);
    font-family: var(--dc-body);
    font-size: 16px;
    color: var(--dc-fg);
    transition: border-color 220ms, box-shadow 220ms;
  }
  .search-form input:focus {
    outline: none;
    border-color: var(--dc-accent);
    box-shadow: 0 0 0 4px var(--dc-accent-soft);
  }
  .search-meta {
    font-size: 13px;
    color: var(--dc-fg-subtle);
    letter-spacing: 0.06em;
    margin-bottom: 36px;
  }

  .search-results {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 28px;
  }
  .search-result {
    display: block;
    background: var(--dc-bg);
    border-radius: var(--radius-md);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition:
      transform var(--dur-med) var(--ease),
      box-shadow var(--dur-med) var(--ease);
  }
  .search-result:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-2);
  }
  .search-result-media {
    background: var(--dc-bg-soft);
    height: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .search-result-media img {
    max-height: 180px;
    width: auto;
    transition: transform var(--dur-slow) var(--ease);
  }
  .search-result:hover .search-result-media img { transform: scale(1.03); }
  .search-result-body { padding: 22px; }
  .search-result-title {
    font-family: var(--dc-heading);
    font-size: 19px;
    font-weight: 400;
    color: var(--dc-ink);
    margin: 0 0 6px;
  }
  .search-result-price {
    font-size: 14px;
    color: var(--dc-fg-subtle);
  }
  .search-result-snippet {
    font-size: 14px;
    color: var(--dc-fg-muted);
    line-height: 1.6;
    margin: 0;
    font-weight: 300;
  }

  .search-empty {
    text-align: center;
    padding: 80px 20px;
    color: var(--dc-fg-muted);
  }
  .search-empty p:first-child {
    font-family: var(--dc-heading);
    font-size: 26px;
    color: var(--dc-ink);
    margin: 0 0 10px;
  }
</style>

<section class="search-page">
  <p class="search-eyebrow dc-reveal-up">Search</p>
  <h1 class="dc-reveal-up dc-delay-1">What are you looking for?</h1>

  <form action="{{ routes.search_url }}" method="get" role="search" class="search-form dc-reveal-up dc-delay-2">
    <label for="search-input" class="visually-hidden">Search</label>
    <input id="search-input"
           type="search"
           name="q"
           value="{{ search.terms | escape }}"
           placeholder="Try Collabloom, joint pain, or marine collagen"
           autofocus>
    <button type="submit" class="dc-btn dc-btn--primary">Search</button>
  </form>

  {% if search.performed %}
    <p class="search-meta dc-reveal-up">
      {{ search.results_count }} result{% if search.results_count != 1 %}s{% endif %} for &ldquo;{{ search.terms | escape }}&rdquo;
    </p>

    {% if search.results.size > 0 %}
      <div class="search-results">
        {% for item in search.results %}
          <a href="{{ item.url }}" class="search-result dc-reveal-up{% cycle '', ' dc-delay-1', ' dc-delay-2', ' dc-delay-3' %}">
            {% if item.object_type == 'product' and item.featured_image %}
              <div class="search-result-media">
                <img src="{{ item.featured_image | image_url: width: 500 }}"
                     alt="{{ item.title | escape }}"
                     loading="lazy">
              </div>
            {% endif %}
            <div class="search-result-body">
              <h3 class="search-result-title">{{ item.title }}</h3>
              {% if item.object_type == 'product' %}
                <p class="search-result-price">{{ item.price | money }}</p>
              {% else %}
                <p class="search-result-snippet">{{ item.content | strip_html | truncate: 110 }}</p>
              {% endif %}
            </div>
          </a>
        {% endfor %}
      </div>
    {% else %}
      <div class="search-empty dc-reveal-up">
        <p>No results found.</p>
        <p>Try a different spelling or browse the <a href="/collections/all" style="color:var(--dc-accent);">full collection</a>.</p>
      </div>
    {% endif %}
  {% endif %}
</section>
