{% comment %}
  Cart template — luxury rebuild.
  Glass-morphism totals card, shimmer on quantity change, animated subtotal.
{% endcomment %}

<style>
  .cart-page {
    max-width: 1080px;
    margin: 0 auto;
    padding: var(--space-6) clamp(20px, 4vw, 48px);
    font-family: var(--dc-body);
    color: var(--dc-ink);
  }
  .cart-eyebrow {
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--dc-accent);
    font-weight: 500;
    margin-bottom: var(--space-1);
  }
  .cart-page h1 {
    font-family: var(--dc-heading);
    font-size: clamp(var(--fs-2xl), 4.4vw, var(--fs-3xl));
    font-weight: 400;
    margin: 0 0 var(--space-4);
    color: var(--dc-ink);
    line-height: var(--lh-tight);
    letter-spacing: var(--ls-tight);
  }

  .cart-grid {
    display: grid;
    grid-template-columns: 1.7fr 1fr;
    gap: var(--space-5);
    align-items: start;
  }
  @media (max-width: 880px) {
    .cart-grid { grid-template-columns: 1fr; gap: var(--space-4); }
  }

  .cart-items { list-style: none; padding: 0; margin: 0; }
  .cart-item {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    gap: 24px;
    align-items: center;
    padding: 24px 0;
    border-bottom: 1px solid var(--dc-line);
    opacity: 0;
    transform: translateY(20px);
    animation: cart-item-in 600ms var(--dc-ease-spring) forwards;
  }
  .cart-item:nth-child(1) { animation-delay: 0.05s; }
  .cart-item:nth-child(2) { animation-delay: 0.13s; }
  .cart-item:nth-child(3) { animation-delay: 0.21s; }
  .cart-item:nth-child(4) { animation-delay: 0.29s; }
  .cart-item:nth-child(5) { animation-delay: 0.37s; }
  .cart-item:nth-child(n+6) { animation-delay: 0.45s; }
  @keyframes cart-item-in { to { opacity: 1; transform: none; } }

  .cart-item-image {
    width: 100px; height: 100px;
    border-radius: var(--dc-radius-md);
    background: var(--dc-bg-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    transition: transform var(--dc-dur-med) var(--dc-ease-spring);
  }
  .cart-item:hover .cart-item-image { transform: scale(1.03); }
  .cart-item-image img { max-height: 88px; width: auto; }

  .cart-item-info { min-width: 0; }
  .cart-item-info a {
    font-family: var(--dc-heading);
    font-size: 19px;
    color: var(--dc-ink);
    text-decoration: none;
    transition: color 220ms;
  }
  .cart-item-info a:hover { color: var(--dc-accent); }
  .cart-item-variant {
    font-size: 12px;
    color: var(--dc-fg-subtle);
    margin: 4px 0 0;
    letter-spacing: 0.04em;
  }

  .cart-item-controls {
    display: flex;
    align-items: center;
    gap: 18px;
  }
  .cart-qty {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--dc-line-strong);
    border-radius: var(--dc-radius-pill);
    overflow: hidden;
    background: var(--dc-bg);
    transition: border-color 220ms, box-shadow 220ms;
  }
  .cart-qty:focus-within {
    border-color: var(--dc-accent);
    box-shadow: 0 0 0 4px var(--dc-accent-soft);
  }
  .cart-qty button {
    background: transparent;
    border: none;
    width: 34px; height: 36px;
    color: var(--dc-fg);
    font-size: 16px;
    cursor: pointer;
    transition: color 200ms;
  }
  .cart-qty button:hover { color: var(--dc-accent); }
  .cart-qty input {
    width: 38px;
    border: none;
    text-align: center;
    background: transparent;
    color: var(--dc-ink);
    font-family: var(--dc-body);
    font-size: 14px;
    font-weight: 500;
    -moz-appearance: textfield;
  }
  .cart-qty input::-webkit-outer-spin-button,
  .cart-qty input::-webkit-inner-spin-button {
    -webkit-appearance: none; margin: 0;
  }
  .cart-item-price {
    font-family: var(--dc-heading);
    font-size: 18px;
    font-weight: 500;
    color: var(--dc-ink);
    min-width: 90px;
    text-align: right;
  }
  .cart-item-remove {
    background: transparent;
    border: none;
    color: var(--dc-fg-subtle);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
    padding: 6px 4px;
    transition: color 220ms;
  }
  .cart-item-remove:hover { color: #c84a4a; }

  /* Plain bordered summary — no glass, no shadow. Restraint. */
  .cart-summary {
    position: sticky;
    top: 100px;
    padding: var(--space-3);
    background: var(--dc-bg);
    border: 1px solid var(--dc-line);
    border-radius: var(--radius-md);
  }
  .cart-summary h2 {
    font-family: var(--dc-heading);
    font-size: 22px;
    font-weight: 500;
    margin: 0 0 22px;
    color: var(--dc-ink);
  }
  .cart-summary-row {
    display: flex;
    justify-content: space-between;
    font-size: 14px;
    color: var(--dc-fg-muted);
    margin-bottom: 12px;
  }
  .cart-summary-row strong { color: var(--dc-ink); font-weight: 500; }
  .cart-summary-total {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin: 24px 0 28px;
    padding-top: 22px;
    border-top: 1px solid var(--dc-line);
  }
  .cart-summary-total .label {
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--dc-fg-subtle);
  }
  .cart-summary-total .amount {
    font-family: var(--dc-heading);
    font-size: 30px;
    color: var(--dc-ink);
    font-weight: 500;
  }
  .cart-summary-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .cart-secure {
    margin-top: 18px;
    font-size: 11px;
    color: var(--dc-fg-subtle);
    letter-spacing: 0.12em;
    text-align: center;
  }
  .cart-secure svg {
    vertical-align: middle;
    margin-right: 6px;
    color: var(--dc-accent);
  }

  .cart-empty {
    text-align: center;
    padding: 80px 20px;
  }
  .cart-empty-icon {
    width: 72px; height: 72px;
    margin: 0 auto 24px;
    color: var(--dc-accent);
    opacity: 0.6;
    animation: empty-pulse 3.4s ease-in-out infinite;
  }
  @keyframes empty-pulse {
    0%,100% { transform: scale(1); opacity: 0.6; }
    50%     { transform: scale(1.05); opacity: 0.85; }
  }
  .cart-empty p {
    font-family: var(--dc-heading);
    font-size: 24px;
    font-weight: 400;
    margin: 0 0 12px;
    color: var(--dc-ink);
  }
  .cart-empty .sub {
    color: var(--dc-fg-muted);
    font-size: 15px;
    line-height: 1.7;
    margin: 0 0 32px;
    font-family: var(--dc-body);
  }
</style>

<section class="cart-page">
  <p class="cart-eyebrow dc-reveal-up">Your order</p>
  <h1 class="dc-reveal-up dc-delay-1">Cart</h1>

  {% if cart.item_count > 0 %}
    <form action="{{ routes.cart_url }}" method="post" novalidate id="cart-form">
      <div class="cart-grid">
        <ul class="cart-items" role="list">
          {% for item in cart.items %}
            <li class="cart-item">
              <a href="{{ item.url }}" class="cart-item-image">
                {% if item.image %}
                  <img src="{{ item.image | image_url: width: 200 }}"
                       alt="{{ item.title | escape }}"
                       loading="lazy"
                       width="100" height="100">
                {% endif %}
              </a>
              <div class="cart-item-info">
                <a href="{{ item.url }}">{{ item.product.title }}</a>
                {% if item.variant.title != 'Default Title' %}
                  <p class="cart-item-variant">{{ item.variant.title }}</p>
                {% endif %}
                <button type="button"
                        class="cart-item-remove"
                        data-cart-remove="{{ item.key }}"
                        aria-label="Remove {{ item.product.title | escape }}">
                  Remove
                </button>
              </div>
              <div class="cart-item-controls">
                <div class="cart-qty">
                  <button type="button" aria-label="Decrease quantity" data-qty-step="-1">−</button>
                  <label class="visually-hidden" for="qty-{{ item.key }}">Quantity for {{ item.product.title | escape }}</label>
                  <input id="qty-{{ item.key }}"
                         type="number"
                         name="updates[{{ item.key }}]"
                         value="{{ item.quantity }}"
                         min="0"
                         inputmode="numeric">
                  <button type="button" aria-label="Increase quantity" data-qty-step="1">+</button>
                </div>
                <span class="cart-item-price">{{ item.final_line_price | money }}</span>
              </div>
            </li>
          {% endfor %}
        </ul>

        <aside class="cart-summary dc-reveal-scale" aria-label="Order summary">
          <h2>Order Summary</h2>
          <div class="cart-summary-row">
            <span>Items ({{ cart.item_count }})</span>
            <strong>{{ cart.items_subtotal_price | money }}</strong>
          </div>
          <div class="cart-summary-row">
            <span>Shipping</span>
            <strong>Calculated at checkout</strong>
          </div>
          <div class="cart-summary-total">
            <span class="label">Total</span>
            <span class="amount">{{ cart.total_price | money }}</span>
          </div>
          <div class="cart-summary-actions">
            <button type="submit" name="checkout" class="dc-btn dc-btn--primary" style="justify-content:center;">
              Checkout
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </button>
            <button type="submit" name="update" class="dc-btn dc-btn--outline" style="justify-content:center;">Update cart</button>
          </div>
          <p class="cart-secure">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            Secure checkout · encrypted in transit
          </p>
        </aside>
      </div>
    </form>
  {% else %}
    <div class="cart-empty dc-reveal-up">
      <svg class="cart-empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="9" cy="21" r="1"></circle>
        <circle cx="20" cy="21" r="1"></circle>
        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
      </svg>
      <p>Nothing in your cart yet.</p>
      <p class="sub">Pick the formula for your goal — skin, joints, body composition, or gut and energy.</p>
      <a href="{{ routes.root_url }}#products" class="dc-btn dc-btn--gold">See the range</a>
    </div>
  {% endif %}
</section>

<script>
  (function() {
    document.querySelectorAll('.cart-qty').forEach(function(group) {
      var input = group.querySelector('input[type="number"]');
      if (!input) return;
      group.querySelectorAll('[data-qty-step]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var step = parseInt(btn.getAttribute('data-qty-step'), 10);
          var v = Math.max(0, (parseInt(input.value, 10) || 0) + step);
          input.value = v;
          input.dispatchEvent(new Event('change', { bubbles: true }));
          input.animate(
            [{ background: 'rgba(232,183,46,0.15)' }, { background: 'transparent' }],
            { duration: 600, easing: 'cubic-bezier(.16,1,.3,1)' }
          );
        });
      });
    });

    document.querySelectorAll('[data-cart-remove]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var key = btn.getAttribute('data-cart-remove');
        var input = document.getElementById('qty-' + key);
        if (!input) return;
        input.value = 0;
        var form = document.getElementById('cart-form');
        if (form.requestSubmit) form.requestSubmit(document.querySelector('button[name="update"]'));
        else form.submit();
      });
    });
  })();
</script>
