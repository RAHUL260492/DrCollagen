{% comment %}Password/coming soon page{% endcomment %}

<section style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#faf6f0 0%,#f0e8d8 100%);font-family:'DM Sans',sans-serif;padding:48px 24px;text-align:center;">
  <div style="max-width:520px;">
    <p style="font-family:'Playfair Display',serif;font-size:32px;font-weight:500;letter-spacing:.08em;color:#1a1225;margin:0 0 36px;">Dr<span style="color:#b8903a;"> Collagen</span></p>
    <h1 style="font-family:'Playfair Display',serif;font-size:52px;font-weight:400;line-height:1.1;margin:0 0 20px;color:#1a1a1a;">{{ shop.name }}</h1>
    {% if shop.password_message != blank %}
      <div style="color:#52493f;font-size:16px;line-height:1.7;margin-bottom:40px;">{{ shop.password_message }}</div>
    {% else %}
      <p style="color:#52493f;font-size:16px;line-height:1.7;margin-bottom:40px;font-weight:300;">We're nearly there. Drop your email and we'll tell you the moment Dr Collagen opens.</p>
    {% endif %}

    {% form 'customer' %}
      {% if form.posted_successfully? %}
        <p style="color:#4a8a2e;font-size:14px;">Thanks — we'll be in touch.</p>
      {% endif %}
      <input type="hidden" name="contact[tags]" value="newsletter, password-page">
      <div style="display:flex;gap:8px;max-width:420px;margin:0 auto 24px;">
        <input type="email" name="contact[email]" placeholder="Enter your email" required style="flex:1;padding:14px 20px;border:1px solid rgba(0,0,0,.12);border-radius:40px;font-size:14px;background:#fff;">
        <button type="submit" style="background:#1a1225;color:#fff;border:none;padding:14px 28px;border-radius:40px;font-size:11px;letter-spacing:.2em;text-transform:uppercase;cursor:pointer;">Notify me</button>
      </div>
    {% endform %}

    <div style="margin-top:60px;">
      <a href="#login" onclick="document.getElementById('login-modal').style.display='flex';return false;" style="font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:#8a7a5a;text-decoration:none;">Enter using password</a>
    </div>
  </div>
</section>

<div id="login-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);align-items:center;justify-content:center;z-index:100;">
  <div style="background:#fff;padding:40px;border-radius:20px;max-width:400px;width:90%;">
    <h3 style="font-family:'Playfair Display',serif;font-size:24px;margin:0 0 20px;">Enter Password</h3>
    {% form 'storefront_password' %}
      {% if form.errors %}
        <p style="color:#c0392b;font-size:13px;margin:0 0 14px;">Incorrect password.</p>
      {% endif %}
      <input type="password" name="password" placeholder="Password" required style="width:100%;padding:14px;border:1px solid rgba(0,0,0,.12);border-radius:10px;font-size:14px;margin-bottom:16px;">
      <button type="submit" style="background:#1a1225;color:#fff;border:none;padding:14px;border-radius:10px;width:100%;font-size:12px;letter-spacing:.2em;text-transform:uppercase;cursor:pointer;">Enter</button>
    {% endform %}
  </div>
</div>
