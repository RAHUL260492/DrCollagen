<script>
(function () {
  var bar = document.getElementById('skl-sticky');
  var hero = document.getElementById('hero');
  if (!bar || !hero) return;
  var ticking = false;
  function check() {
    var past = (window.scrollY || 0) > (hero.offsetTop + hero.offsetHeight - 80);
    bar.classList.toggle('is-visible', past);
    bar.setAttribute('aria-hidden', past ? 'false' : 'true');
    ticking = false;
  }
  window.addEventListener('scroll', function () { if (!ticking) { ticking = true; requestAnimationFrame(check); } }, { passive: true });
  check();
  var btn = document.getElementById('skl-sticky-buy');
  if (btn) btn.addEventListener('click', function (e) {
    var form = document.getElementById('skelecoll-buy-form');
    if (form && form.requestSubmit) { e.preventDefault(); form.requestSubmit(); }
  });
})();
</script>

