<script>
  /* Skelecoll hero slider — coverflow carousel (mirrors Collabloom's). */
  (function () {
    var slider = document.getElementById('skelecoll-slider');
    if (!slider) return;
    var wrap = slider.closest('.skl-slider-wrap');
    if (!wrap) return;
    var track = slider.querySelector('[data-skl-track]');
    var slides = Array.prototype.slice.call(slider.querySelectorAll('.skl-slide'));
    var thumbs = Array.prototype.slice.call(wrap.querySelectorAll('.skl-thumb'));
    var prevBtn = slider.querySelector('[data-skl-prev]');
    var nextBtn = slider.querySelector('[data-skl-next]');
    if (!track || slides.length < 2) return;

    var REDUCED_MOTION = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var AUTO_MS = 8000;
    var idx = 0;
    var timer = null;

    function position() {
      var slide = slides[idx];
      if (!slide) return;
      var sliderW = slider.clientWidth;
      var slideCenter = slide.offsetLeft + (slide.offsetWidth / 2);
      var viewportCenter = sliderW / 2;
      var offset = viewportCenter - slideCenter;
      track.style.transform = 'translateX(' + offset + 'px)';

      slides.forEach(function (s, i) {
        var active = (i === idx);
        s.classList.toggle('is-active', active);
        s.setAttribute('aria-current', active ? 'true' : 'false');
      });
      thumbs.forEach(function (t, i) {
        var active = (i === idx);
        t.classList.toggle('is-active', active);
        var btn = t.querySelector('button');
        if (btn) btn.setAttribute('aria-selected', active ? 'true' : 'false');
      });
    }
    function go(newIdx) {
      idx = ((newIdx % slides.length) + slides.length) % slides.length;
      position();
    }
    function next() { go(idx + 1); }
    function prev() { go(idx - 1); }
    function start() { stop(); if (REDUCED_MOTION) return; timer = setInterval(next, AUTO_MS); }
    function stop() { if (timer) { clearInterval(timer); timer = null; } }

    if (nextBtn) nextBtn.addEventListener('click', function () { next(); start(); });
    if (prevBtn) prevBtn.addEventListener('click', function () { prev(); start(); });
    thumbs.forEach(function (t, i) {
      var btn = t.querySelector('button');
      if (btn) btn.addEventListener('click', function () { go(i); start(); });
    });
    slider.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowLeft')  { e.preventDefault(); prev(); start(); }
      if (e.key === 'ArrowRight') { e.preventDefault(); next(); start(); }
    });
    wrap.addEventListener('mouseenter', stop);
    wrap.addEventListener('mouseleave', start);
    wrap.addEventListener('focusin', stop);
    wrap.addEventListener('focusout', start);

    var debounced;
    window.addEventListener('resize', function () {
      clearTimeout(debounced);
      debounced = setTimeout(position, 120);
    });
    slides.forEach(function (s) {
      var img = s.querySelector('img');
      if (img && !img.complete) img.addEventListener('load', position, { once: true });
    });
    requestAnimationFrame(function () { setTimeout(position, 50); });
    start();
  })();
</script>

