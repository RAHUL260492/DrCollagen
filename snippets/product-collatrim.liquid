<script>
// ═══ NAV SCROLL STATE ═══════════════════════════════════════════════
(function() {
  const nav = document.getElementById('navbar');
  function update() { nav.classList.toggle('scrolled', window.scrollY > 60); }
  (function(){var navTick=false;window.addEventListener('scroll',function(){if(navTick)return;navTick=true;requestAnimationFrame(function(){update();navTick=false;});},{passive:true});})();
  update();
})();

// ═══ SCROLL REVEAL (WITH MOTION SPRING PHYSICS) ═════════════════════
(function() {
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.querySelectorAll('.reveal').forEach(el => el.classList.add('visible'));
    return;
  }
  const { inView, animate } = Motion;
  inView(".reveal", ({ target }) => {
    let delay = 0;
    for (let i = 1; i <= 6; i++) {
      if (target.classList.contains(`reveal-delay-${i}`)) {
        delay = i * 0.12;
        break;
      }
    }
    animate(target, 
      { opacity: [0, 1], y: [40, 0] }, 
      { delay, duration: 0.85, easing: [0.16, 1, 0.3, 1] }
    );
  });
})();

// ═══ COUNTER ANIMATION ══════════════════════════════════════════════
(function() {
  const counters = document.querySelectorAll('.counter');
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      const el = e.target;
      const target = parseInt(el.dataset.target || '0', 10);
      const duration = 1500;
      const start = performance.now();
      function step(now) {
        const t = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - t, 3);
        el.textContent = Math.round(eased * target).toLocaleString();
        if (t < 1) requestAnimationFrame(step);
        else el.textContent = target.toLocaleString();
      }
      requestAnimationFrame(step);
      io.unobserve(el);
    });
  }, { threshold: 0.5 });
  counters.forEach(c => io.observe(c));
})();

// ═══ CUSTOM CURSOR (WITH MOTION SPRING PHYSICS) ═════════════════════
(function(){
  const dot  = document.getElementById('cursor-dot');
  const ring = document.getElementById('cursor-ring');
  if (!dot || !ring) return;
  if (window.matchMedia('(hover: none)').matches || window.innerWidth < 900) return;
  
  const { animate } = Motion;
  let mx = -100, my = -100;
  
  document.addEventListener('mousemove', e => {
    mx = e.clientX;
    my = e.clientY;
    dot.style.transform = `translate3d(${mx}px, ${my}px, 0) translate(-50%, -50%)`;
    
    animate(ring, {
      transform: [`translate3d(${mx}px, ${my}px, 0) translate(-50%, -50%)`]
    }, {
      type: "spring",
      stiffness: 300,
      damping: 25,
      mass: 0.5
    });
  });
  
  document.querySelectorAll('a, button, .ing-card, .rev-card, .use-step, .faq-item summary, .pillar-card, .product-card')
    .forEach(el=>{
      el.addEventListener('mouseenter',()=>document.body.classList.add('hovering'));
      el.addEventListener('mouseleave',()=>document.body.classList.remove('hovering'));
    });
})();

// ═══ FAQ ACCORDION SPRING ANIMATION ═════════════════════════════════
(function() {
  const { animate } = Motion;
  document.querySelectorAll('.faq-item').forEach(item => {
    const summary = item.querySelector('summary');
    const answer = item.querySelector('.faq-answer');
    if (!summary || !answer) return;
    
    answer.style.overflow = 'hidden';
    
    summary.addEventListener('click', (e) => {
      e.preventDefault();
      const isOpen = item.hasAttribute('open');
      
      if (!isOpen) {
        item.setAttribute('open', '');
        const height = answer.scrollHeight;
        
        animate(answer, 
          { height: [0, height], opacity: [0, 1], paddingBottom: ["0px", "22px"] }, 
          { type: "spring", stiffness: 300, damping: 26 }
        );
      } else {
        const height = answer.scrollHeight;
        animate(answer, 
          { height: [height, 0], opacity: [1, 0], paddingBottom: ["22px", "0px"] }, 
          { type: "spring", stiffness: 300, damping: 26 }
        ).then(() => {
          item.removeAttribute('open');
          answer.style.height = '';
          answer.style.opacity = '';
          answer.style.paddingBottom = '';
        });
      }
    });
  });
})();


// ═══ AMBIENT PARTICLES ══════════════════════════════════════════════
(function(){
  const canvas = document.getElementById('particles-canvas');
  if (!canvas) return;
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  const ctx = canvas.getContext('2d');
  let W, H, parts = [];
  function resize(){ W=canvas.width=window.innerWidth; H=canvas.height=window.innerHeight; }
  resize(); window.addEventListener('resize', resize, { passive: true });
  const rand=(a,b)=>Math.random()*(b-a)+a;
  // Per-product olive / warm-gold palette
  const hues = [
    'rgba(143,168,82,ALPHA)',
    'rgba(210,200,130,ALPHA)',
    'rgba(120,145,60,ALPHA)'
  ];
  const count = window.innerWidth < 900 ? 24 : 44;
  for (let i=0;i<count;i++){
    parts.push({
      x:rand(0,W), y:rand(0,H),
      r:rand(.3,1.6),
      vx:rand(-.12,.12), vy:rand(-.22,-.04),
      alpha:rand(.05,.3),
      hue:hues[Math.floor(Math.random()*hues.length)]
    });
  }
  function draw(){
    ctx.clearRect(0,0,W,H);
    for (const p of parts){
      ctx.beginPath(); ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
      ctx.fillStyle=p.hue.replace('ALPHA',p.alpha.toFixed(2));
      ctx.fill();
      p.x+=p.vx; p.y+=p.vy;
      if (p.y<-4)    p.y = H+4;
      if (p.x<-4)    p.x = W+4;
      if (p.x>W+4)   p.x = -4;
    }
    requestAnimationFrame(draw);
  }
  draw();
})();

// ═══ LETTER-SPLIT (hero title) ══════════════════════════════════════
(function(){
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  document.querySelectorAll('[data-split]').forEach(el => {
    Array.from(el.childNodes).forEach(node => {
      if (node.nodeType !== 3) return;
      const frag = document.createDocumentFragment();
      node.textContent.split(/(\s+)/).forEach(seg => {
        if (!seg) return;
        if (/^\s+$/.test(seg)) { frag.appendChild(document.createTextNode(seg)); return; }
        const w = document.createElement('span'); w.className='split-word';
        for (const ch of seg){
          const c = document.createElement('span'); c.className='split-char';
          c.style.animationDelay = (Math.random()*.35 + .2).toFixed(2) + 's';
          c.textContent = ch; w.appendChild(c);
        }
        frag.appendChild(w);
      });
      node.parentNode.replaceChild(frag, node);
    });
  });
})();

// ═══ 3D TILT on ingredient cards ════════════════════════════════════
(function(){
  if (window.matchMedia('(hover: none)').matches ||
      window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  const MAX = 6;
  document.querySelectorAll('.ing-card').forEach(card => {
    card.addEventListener('mousemove', e => {
      const r = card.getBoundingClientRect();
      const x = (e.clientX - r.left) / r.width  - .5;
      const y = (e.clientY - r.top)  / r.height - .5;
      card.style.transform =
        `perspective(900px) rotateX(${(-y*MAX).toFixed(2)}deg) rotateY(${(x*MAX).toFixed(2)}deg) translateZ(0)`;
      card.classList.add('tilt-active');
    });
    card.addEventListener('mouseleave', () => {
      card.style.transform = '';
      card.classList.remove('tilt-active');
    });
  });
})();

// ═══ MAGNETIC CTA ═══════════════════════════════════════════════════
(function(){
  if (window.matchMedia('(hover: none)').matches ||
      window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  const S = 10;
  document.querySelectorAll('.btn-primary').forEach(btn => {
    btn.addEventListener('mousemove', e => {
      const r = btn.getBoundingClientRect();
      const x = (e.clientX - (r.left + r.width/2))  / r.width  * S;
      const y = (e.clientY - (r.top  + r.height/2)) / r.height * S;
      btn.style.transform = `translate(${x.toFixed(2)}px, ${y.toFixed(2)}px)`;
    });
    btn.addEventListener('mouseleave', () => { btn.style.transform = ''; });
  });
})();

// ═══ MOBILE HAMBURGER DRAWER ════════════════════════════════════════
(function() {
  const btn = document.getElementById('nav-hamburger');
  const drawer = document.getElementById('mobile-drawer');
  if (!btn || !drawer) return;
  function setOpen(open) {
    btn.setAttribute('aria-expanded', String(open));
    btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    drawer.classList.toggle('open', open);
    drawer.setAttribute('aria-hidden', String(!open));
    document.body.classList.toggle('drawer-open', open);
  }
  btn.addEventListener('click', () => setOpen(!drawer.classList.contains('open')));
  drawer.querySelectorAll('a').forEach(a => a.addEventListener('click', () => setOpen(false)));
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && drawer.classList.contains('open')) { setOpen(false); btn.focus(); }
  });
})();

</script>