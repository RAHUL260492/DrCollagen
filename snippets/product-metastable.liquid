      font-weight: 700;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: rgba(0,0,0,.55);
      white-space: nowrap;
    }

  
    /* Formulated by Doctors badge — sits just above the hero title */
    .hero-doc-badge {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 6px 14px;
      margin-bottom: 16px;
