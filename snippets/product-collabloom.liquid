<script>
  /* Collabloom hero slider — coverflow carousel with arrows + thumbnails.
     - Auto-advances every 7s (paused on hover/focus)
     - Center slide highlighted, side slides faded + scaled down
     - Arrows + thumbnail strip jump to specific slide
     - Track shifts via translateX so the active slide is always centered
  */
  (function () {
    var slider = document.getElementById('collabloom-slider');
    if (!slider) return;
    var wrap = slider.closest('.cb-slider-wrap');
    if (!wrap) return;
    var track = slider.querySelector('[data-cb-track]');
    var slides = Array.prototype.slice.call(slider.querySelectorAll('.cb-slide'));
    var thumbs = Array.prototype.slice.call(wrap.querySelectorAll('.cb-thumb'));
    var prevBtn = slider.querySelector('[data-cb-prev]');
    var nextBtn = slider.querySelector('[data-cb-next]');
    if (!track || slides.length < 2) return;

    var REDUCED_MOTION = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    /* Medium auto-advance: 8 seconds per slide gives a comfortable reading
       window for the infographic slides (especially "Who is it for?",
       "Key Benefits", etc.) while still feeling alive. */
    var AUTO_MS = 8000;
    var idx = 0;
    var timer = null;

    function position() {
      var slide = slides[idx];
      if (!slide) return;
      // Centre the active slide within the slider viewport
      var sliderW = slider.clientWidth;
      var slideCenter = slide.offsetLeft + (slide.offsetWidth / 2);
      var viewportCenter = sliderW / 2;
      var offset = viewportCenter - slideCenter;
      track.style.transform = 'translateX(' + offset + 'px)';

      slides.forEach(function (s, i) {
        var active = (i === idx);
        s.classList.toggle('is-active', active);
        s.setAttribute('aria-current', active ? 'true' : 'false');
      });
      thumbs.forEach(function (t, i) {
        var active = (i === idx);
        t.classList.toggle('is-active', active);
        var btn = t.querySelector('button');
        if (btn) btn.setAttribute('aria-selected', active ? 'true' : 'false');
      });
    }

    function go(newIdx) {
      idx = ((newIdx % slides.length) + slides.length) % slides.length;
      position();
    }
    function next() { go(idx + 1); }
    function prev() { go(idx - 1); }

    function start() {
      stop();
      if (REDUCED_MOTION) return;
      timer = setInterval(next, AUTO_MS);
    }
    function stop() { if (timer) { clearInterval(timer); timer = null; } }

    if (nextBtn) nextBtn.addEventListener('click', function () { next(); start(); });
    if (prevBtn) prevBtn.addEventListener('click', function () { prev(); start(); });

    thumbs.forEach(function (t, i) {
      var btn = t.querySelector('button');
      if (btn) btn.addEventListener('click', function () { go(i); start(); });
    });

    // Keyboard nav within the slider
    slider.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowLeft')  { e.preventDefault(); prev(); start(); }
      if (e.key === 'ArrowRight') { e.preventDefault(); next(); start(); }
    });

    // Pause auto-advance on hover/focus
    wrap.addEventListener('mouseenter', stop);
    wrap.addEventListener('mouseleave', start);
    wrap.addEventListener('focusin', stop);
    wrap.addEventListener('focusout', start);

    // Re-centre on resize and when images finish loading (sizes can change)
    var debounced;
    window.addEventListener('resize', function () {
      clearTimeout(debounced);
      debounced = setTimeout(position, 120);
    });
    slides.forEach(function (s) {
      var img = s.querySelector('img');
      if (img && !img.complete) img.addEventListener('load', position, { once: true });
    });

    // Initial paint: wait one frame so flex layout settles
    requestAnimationFrame(function () { setTimeout(position, 50); });
    start();
  })();

  /* Pack / variant selector — keeps every buy box in sync:
     updates the hidden variant id on all forms, the hero price,
     the strike-through "was" price + save badge, and the CTA button label. */
  (function () {
    var groups = Array.prototype.slice.call(document.querySelectorAll('.dc-pack-select'));
    if (!groups.length) return;

    function setText(sel, txt) {
      document.querySelectorAll(sel).forEach(function (el) { el.textContent = txt; });
    }
    function showHide(sel, show, txt) {
      document.querySelectorAll(sel).forEach(function (el) {
        el.style.display = show ? '' : 'none';
        if (show && txt != null) el.textContent = txt;
      });
    }

    function select(id, price, was, save) {
      // sync the active state across ALL pack groups for the same variant
      groups.forEach(function (group) {
        group.querySelectorAll('.dc-pack').forEach(function (b) {
          var on = b.getAttribute('data-variant-id') === id;
          b.classList.toggle('is-active', on);
          b.setAttribute('aria-checked', on ? 'true' : 'false');
        });
      });
      document.querySelectorAll('.js-cb-variant-id').forEach(function (i) { i.value = id; });
      setText('.js-cb-price', price);
      setText('.js-cb-buy-label', price);
      showHide('.js-cb-was', !!was, was || '');
      showHide('.js-cb-save', !!was, was ? ('Save ' + save + '%') : '');
    }

    groups.forEach(function (group) {
      group.addEventListener('click', function (e) {
        var btn = e.target.closest('.dc-pack');
        if (!btn || btn.disabled) return;
        select(
          btn.getAttribute('data-variant-id'),
          btn.getAttribute('data-price') || '',
          btn.getAttribute('data-was') || '',
          btn.getAttribute('data-save') || ''
        );
      });
      // keyboard support for the radio group
      group.addEventListener('keydown', function (e) {
        if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return;
        var packs = Array.prototype.slice.call(group.querySelectorAll('.dc-pack:not([disabled])'));
        var cur = group.querySelector('.dc-pack.is-active');
        var i = packs.indexOf(cur);
        if (i < 0) return;
        var next = e.key === 'ArrowRight' ? packs[(i + 1) % packs.length] : packs[(i - 1 + packs.length) % packs.length];
        if (next) { next.click(); next.focus(); e.preventDefault(); }
      });
    });
  })();
</script>

