{%- comment -%}
  Resolve the live Shopify product so prices and the Buy button always
  match the storefront. Falls back to the launch-pricing static values
  ONLY if the Product hasn't been created in admin yet — once it exists
  with the right handle, every price and CTA pulls from Shopify.
{%- endcomment -%}
{%- assign dc_handle = 'collabloom' -%}
{%- assign dc_product = all_products[dc_handle] -%}
{%- if dc_product and dc_product.id != blank -%}
  {%- assign dc_price = dc_product.price | money -%}
  {%- if dc_product.compare_at_price > dc_product.price -%}
    {%- assign dc_was = dc_product.compare_at_price | money -%}
    {%- assign dc_save_pct = dc_product.compare_at_price | minus: dc_product.price | times: 100.0 | divided_by: dc_product.compare_at_price | round -%}
  {%- endif -%}
  {%- assign dc_variant_id = dc_product.selected_or_first_available_variant.id -%}
  {%- assign dc_available = dc_product.available -%}
{%- else -%}
  {%- assign dc_price = '₹1,899' -%}
  {%- assign dc_was = '₹2,375' -%}
  {%- assign dc_save_pct = 20 -%}
  {%- assign dc_available = false -%}
{%- endif -%}

<style>
    /* Kill any rogue horizontal scroll on this page (sliders, decorative
       overlays, etc. should never push the viewport wider than itself). */
    html, body { overflow-x: hidden; max-width: 100vw; }

    /* ─── DESIGN TOKENS (per-product theme: Collabloom — soft rose pink) ─── */
    :root {
      --accent:        #e07a9e;
      --accent-deep:   #b05578;
      --accent-glow:   rgba(224,122,158,.32);
      --accent-soft:   rgba(224,122,158,.09);
      --theme-1:       #fde4ec;    /* hero background tint */
      --theme-2:       #fef0f3;
      --theme-3:       #fad6e0;
      --ink:           #2a1225;
      --warm-dim:      #6a5065;
      --muted:         #7a6872;
      --heading:       'Playfair Display', Georgia, serif;
      --body:          'DM Sans', -apple-system, sans-serif;
    }

    /* ─── METALLIC ROSE ─────────────────────────────────────────── */
    em.shine, h1 em, h2 em {
      background: linear-gradient(135deg,#ffeef3 0%,#ffc4d4 22%,#f095ae 42%,#e07a9e 58%,#b05578 78%,#833856 100%);
      background-size: 220% 220%;
      -webkit-background-clip: text; background-clip: text;
      -webkit-text-fill-color: transparent; color: transparent;
      filter: drop-shadow(0 1px 0 rgba(255,220,230,.55)) drop-shadow(0 0 14px rgba(224,122,158,.45));
      animation: shimmer 6s ease-in-out infinite;
      font-style: italic; font-weight: 400;
    }
    @keyframes shimmer { 0%,100%{background-position:0% 50%} 50%{background-position:100% 50%} }

    /* ─── RESET ─────────────────────────────────────────────────── */
    *,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--body);
      background: #ffffff;
      color: var(--ink);
      overflow-x: hidden;
      line-height: 1.6;
    }
    img { display: block; max-width: 100%; }
    a { text-decoration: none; color: inherit; }
    button { cursor: pointer; border: none; background: none; font-family: var(--body); }

    /* ─── FILM GRAIN ────────────────────────────────────────────── */
    #film-grain {
      position: fixed; inset: -50%; z-index: 100;
      width: 200%; height: 200%;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
      background-size: 256px 256px;
      opacity: 0.028;
      pointer-events: none;
      animation: grain-move .6s steps(2) infinite;
    }
    @keyframes grain-move {
      0%{transform:translate(0,0)} 25%{transform:translate(-3px,2px)}
      50%{transform:translate(2px,-3px)} 75%{transform:translate(3px,1px)}
      100%{transform:translate(-1px,3px)}
    }

    /* ─── NAV ───────────────────────────────────────────────────── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 500;
      padding: 22px 48px;
      display: flex; align-items: center; justify-content: space-between;
      transition: background .4s ease, padding .4s ease, backdrop-filter .4s ease, border-color .4s ease;
      border-bottom: 1px solid transparent;
    }
    nav.scrolled {
      background: rgba(255,255,255,.92);
      backdrop-filter: blur(18px); -webkit-backdrop-filter: blur(18px);
      border-bottom-color: rgba(0,0,0,.05);
      padding: 14px 48px;
    }
    .nav-logo {
      font-family: var(--heading); font-size: 20px; font-weight: 600;
      letter-spacing: .08em;
    }
    .nav-logo span { color: var(--accent); }
    .nav-back {
      font-size: 11px; font-weight: 500; letter-spacing: .2em;
      text-transform: uppercase; color: var(--warm-dim);
      display: inline-flex; align-items: center; gap: 10px;
      transition: color .3s, gap .3s;
    }
    .nav-back:hover { color: var(--accent); gap: 14px; }
    .nav-back .arrow { font-size: 14px; transform: translateY(-1px); }
    .nav-cta {
      font-size: 11px; font-weight: 500; letter-spacing: .2em;
      text-transform: uppercase;
      padding: 10px 22px; color: var(--accent);
      border: 1px solid rgba(224,122,158,.42); border-radius: 40px;
      transition: background .3s, color .3s, border-color .3s;
    }
    .nav-cta:hover { background: var(--accent); color: #fff; border-color: var(--accent); }

    /* ─── HERO ──────────────────────────────────────────────────── */
    #hero {
      position: relative; min-height: 100vh; min-height: 100svh;
      background: radial-gradient(ellipse at 30% 20%, var(--theme-1) 0%, var(--theme-2) 50%, #ffffff 100%);
      padding: 140px 6vw 80px;
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 60px; align-items: center;
      overflow: hidden;
    }
    #hero::before {
      content: ''; position: absolute;
      top: -30%; right: -15%;
      width: 600px; height: 600px; border-radius: 50%;
      background: radial-gradient(circle, var(--accent-soft) 0%, transparent 60%);
      pointer-events: none;
    }
    .hero-text { position: relative; z-index: 2; }
    .hero-breadcrumb {
      font-size: 11px; font-weight: 700; letter-spacing: .28em;
      text-transform: uppercase; color: var(--accent-deep);
      margin-bottom: 24px;
    }
    .hero-breadcrumb a { transition: color .3s; }
    .hero-breadcrumb a:hover { color: var(--accent-deep); }
    .hero-title {
      font-family: var(--heading);
      font-size: clamp(52px, 7vw, 96px);
      font-weight: 300; line-height: 1.02;
      margin-bottom: 20px;
      letter-spacing: -.01em;
    }
    /* Trademark mark: tiny, upright, pinned to the top-right of the name */
    .hero-title .hero-tm {
      font-size: 0.24em;
      font-style: normal;
      font-weight: 400;
      vertical-align: super;
      line-height: 1;
      margin-left: 0.06em;
      letter-spacing: 0;
    }
    .hero-tagline {
      font-size: clamp(17px, 1.6vw, 21px);
      font-weight: 300;
      color: var(--warm-dim);
      line-height: 1.6;
      max-width: 480px;
      margin-bottom: 32px;
    }
    .hero-bullets {
      list-style: none; display: flex; flex-direction: column; gap: 10px;
      margin-bottom: 40px;
    }
    .hero-bullets li {
      font-size: 14px; font-weight: 400; color: var(--ink);
      display: flex; align-items: center; gap: 12px;
    }
    .hero-bullets li::before {
      content: '✦'; color: var(--accent);
      font-size: 12px; flex-shrink: 0;
    }
    .hero-actions {
      display: flex; gap: 14px; flex-wrap: wrap; align-items: center;
    }
    .btn-primary {
      position: relative; overflow: hidden;
      padding: 14px 34px;
      background: linear-gradient(135deg, #b05578 0%, #833856 50%, #2a1225 100%);
      color: #ffffff; font-size: 11px; font-weight: 700; letter-spacing: .2em;
      text-transform: uppercase; border-radius: 40px;
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.15),
        inset 0 -1px 0 rgba(0,0,0,.35),
        0 6px 18px rgba(42,18,37,.35),
        0 0 0 1px rgba(176,85,120,.45);
      text-shadow: 0 1px 2px rgba(0,0,0,0.25);
      transition: transform .3s, box-shadow .3s, filter .3s;
      display: inline-block;
    }
    .btn-primary::before {
      content: ""; position: absolute; top: 0; left: -120%; width: 60%; height: 100%;
      background: linear-gradient(110deg, transparent 20%, rgba(255,255,255,.55) 50%, transparent 80%);
      transform: skewX(-18deg); pointer-events: none;
      transition: left .9s cubic-bezier(.2,.8,.2,1);
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      filter: brightness(1.10) saturate(1.1);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.25),
        inset 0 -1px 0 rgba(0,0,0,.4),
        0 16px 44px rgba(42,18,37,.4),
        0 0 0 1px rgba(176,85,120,.55);
    }
    .btn-primary:hover::before { left: 120%; }
    .btn-outline {
      padding: 14px 30px; border: 1px solid rgba(42,18,37,.22);
      color: var(--ink);
      font-size: 11px; font-weight: 500; letter-spacing: .2em;
      text-transform: uppercase; border-radius: 40px;
      transition: border-color .3s, background .3s;
    }
    .btn-outline:hover { border-color: rgba(42,18,37,.5); background: rgba(42,18,37,.03); }

    .hero-price-row {
      display: flex; align-items: baseline; gap: 18px;
      margin-bottom: 12px;
    }
    .hero-price {
      font-family: var(--heading);
      font-size: 30px; font-weight: 400;
      color: var(--ink);
    }
    .hero-price-was {
      font-size: 16px; font-weight: 300;
      color: var(--muted);
      text-decoration: line-through;
    }
    .hero-price-save {
      font-size: 10px; font-weight: 600; letter-spacing: .15em;
      text-transform: uppercase;
      padding: 4px 10px; border-radius: 20px;
      background: var(--accent-soft);
      color: var(--accent-deep);
    }

    /* ─── Pack / variant selector ─── */
    .dc-pack-select {
      display: flex; flex-wrap: wrap; gap: 10px;
      margin: 16px 0 22px; max-width: 480px;
    }
    .dc-pack {
      flex: 1 1 140px; min-width: 140px; text-align: left;
      border: 1.5px solid rgba(176, 85, 120, .30);
      background: #fff; border-radius: 14px;
      padding: 12px 14px; cursor: pointer; position: relative;
      display: flex; flex-direction: column; gap: 3px;
      transition: border-color .2s var(--dc-ease-soft, ease),
                  background .2s var(--dc-ease-soft, ease),
                  box-shadow .2s var(--dc-ease-soft, ease);
    }
    .dc-pack:hover { border-color: var(--accent); }
    .dc-pack.is-active {
      border-color: var(--accent-deep);
      background: rgba(176, 85, 120, .06);
      box-shadow: inset 0 0 0 1px var(--accent-deep);
    }
    .dc-pack:focus-visible { outline: 2px solid var(--accent-deep); outline-offset: 2px; }
    .dc-pack[disabled] { opacity: .45; cursor: not-allowed; }
    .dc-pack__name  { font-weight: 600; font-size: 14px; color: var(--ink); }
    .dc-pack__price { font-size: 13px; color: var(--muted); }
    .dc-pack__save  { font-size: 11px; font-weight: 600; color: var(--accent-deep); }
    .dc-pack--rec { border-color: var(--accent-deep); }
    .dc-pack__rec {
      position: absolute; top: -10px; right: 10px;
      background: var(--accent-deep); color: #fff;
      font-size: 9px; letter-spacing: .08em; text-transform: uppercase;
      font-weight: 700; padding: 3px 8px; border-radius: 999px;
      white-space: nowrap;
    }

    .hero-visual {
      position: relative; z-index: 2;
      display: flex; align-items: center; justify-content: center;
      /* Safety: contain the slider track so it can't push the page wider */
      max-width: 100%;
      min-width: 0;
      overflow: hidden;
    }
    .hero-bottle-wrap {
      position: relative;
      animation: float 6s ease-in-out infinite;
    }
    @keyframes float {
      0%,100% { transform: translateY(0); }
      50% { transform: translateY(-18px); }
    }
    .hero-bottle-wrap img {
      height: clamp(340px, 52vh, 560px);
      width: auto;
      filter: drop-shadow(0 40px 80px rgba(176,85,120,.3));
    }
    .hero-bottle-wrap::after {
      content: '';
      position: absolute;
      bottom: -40px; left: 50%;
      transform: translateX(-50%);
      width: 260px; height: 30px;
      background: radial-gradient(ellipse, rgba(42,18,37,.18) 0%, transparent 70%);
      border-radius: 50%;
      filter: blur(8px);
    }
    .hero-badge-float {
      position: absolute; top: 12%; right: 0;
      background: #fff;
      border: 1px solid var(--accent-soft);
      padding: 14px 20px; border-radius: 14px;
      box-shadow: 0 8px 28px rgba(176,85,120,.12);
      font-size: 11px; font-weight: 500;
      letter-spacing: .05em; color: var(--ink);
      max-width: 180px;
    }
    .hero-badge-float strong { color: var(--accent-deep); }

    /* ─── HERO SLIDER (Collabloom) ──────────────────────────────────
       Coverflow-style carousel: 3 cards visible, center highlighted,
       side cards faded and scaled down. Auto-advances every 7s,
       pauses on hover. Manual arrows + thumbnail strip below.
       ─────────────────────────────────────────────────────────────── */
    .cb-slider-wrap {
      position: relative;
      width: clamp(280px, 62vw, 860px);
      max-width: 100%;
      min-width: 0;
    }
    .cb-slider {
      position: relative;
      width: 100%;
      max-width: 100%;
      min-width: 0;
      height: clamp(520px, 76vh, 780px);
      overflow: hidden;
      border-radius: 26px;
      contain: layout paint;
      /* Soft edge fade so side cards melt out toward the page background */
      -webkit-mask-image: linear-gradient(to right, transparent 0%, #000 9%, #000 91%, transparent 100%);
              mask-image: linear-gradient(to right, transparent 0%, #000 9%, #000 91%, transparent 100%);
    }
    .cb-slider-track {
      display: flex;
      align-items: center;
      gap: 28px;
      height: 100%;
      padding: 14px 0;
      transition: transform 700ms cubic-bezier(0.22, 1, 0.36, 1);
      will-change: transform;
    }
    .cb-slide {
      flex: 0 0 auto;
      width: clamp(340px, 46vw, 580px);
      height: 100%;
      border-radius: 24px;
      overflow: hidden;
      /* Card background matches the image corners (#fef0f3) so there's
         no visible seam between the image edge and the card itself.
         The card also has a soft outer halo in the same tone — this
         dissolves the card edges into the hero gradient. */
      background: #fef0f3;
      box-shadow:
        0 0 0 1px rgba(254, 240, 243, 0.5),
        0 30px 80px -30px rgba(254, 220, 232, 0.65),
        0 14px 40px -16px rgba(254, 230, 240, 0.55);
      opacity: 0.42;
      transform: scale(0.92);
      transition:
        opacity 700ms cubic-bezier(0.22, 1, 0.36, 1),
        transform 700ms cubic-bezier(0.22, 1, 0.36, 1),
        box-shadow 700ms cubic-bezier(0.22, 1, 0.36, 1);
    }
    .cb-slide.is-active {
      opacity: 1;
      transform: scale(1);
      box-shadow:
        0 0 0 1px rgba(254, 240, 243, 0.7),
        0 38px 100px -32px rgba(224, 122, 158, 0.32),
        0 18px 48px -20px rgba(254, 220, 232, 0.6);
    }
    /* Images run edge-to-edge with object-fit:contain. Since the card
       background now matches the image corners, there's no visible
       transition between the two. */
    .cb-slide img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      object-position: center;
      display: block;
      padding: 0;
      box-sizing: border-box;
    }
    /* Slide 1 — transparent PNG bottle. Uses the same soft pink card
       background, with a subtle radial tint behind the bottle for depth. */
    .cb-slide--bottle {
      display: flex; align-items: center; justify-content: center;
      background:
        radial-gradient(ellipse at 50% 42%, var(--theme-1) 0%, transparent 70%),
        #fef0f3;
    }
    .cb-slide--bottle img {
      width: 70%;
      height: 88%;
      padding: 0;
      filter: drop-shadow(0 24px 48px rgba(176,85,120,.36));
    }

    /* Prev / Next arrows */
    .cb-arrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 5;
      width: 46px; height: 46px;
      border-radius: 50%;
      background: rgba(255,255,255,0.94);
      border: 1px solid var(--accent-soft);
      color: var(--accent-deep);
      font-family: var(--heading);
      font-size: 26px;
      font-weight: 400;
      line-height: 1;
      padding: 0 0 4px 0;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 6px 22px rgba(176,85,120,.20);
      transition:
        background 220ms var(--dc-ease-soft),
        box-shadow 220ms var(--dc-ease-soft),
        transform 220ms var(--dc-ease-soft);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
    }
    .cb-arrow:hover {
      background: #fff;
      box-shadow: 0 10px 30px rgba(176,85,120,.32);
      transform: translateY(-50%) scale(1.06);
    }
    .cb-arrow:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
    .cb-arrow--prev { left: 18px; }
    .cb-arrow--next { right: 18px; }

    /* Thumbnail strip below the slider */
    .cb-thumbs {
      display: flex;
      justify-content: center;
      gap: 10px;
      margin: 22px 0 0;
      padding: 0;
      list-style: none;
      flex-wrap: wrap;
    }
    .cb-thumb {
      margin: 0; padding: 0;
    }
    .cb-thumb button {
      display: block;
      width: 58px; height: 72px;
      padding: 0;
      border: 2px solid transparent;
      border-radius: 10px;
      overflow: hidden;
      background: var(--theme-2);
      cursor: pointer;
      opacity: 0.55;
      transition:
        opacity 220ms var(--dc-ease-soft),
        border-color 220ms var(--dc-ease-soft),
        transform 220ms var(--dc-ease-soft);
    }
    .cb-thumb button:hover { opacity: 0.85; transform: translateY(-2px); }
    .cb-thumb.is-active button {
      opacity: 1;
      border-color: var(--accent);
      transform: translateY(-2px) scale(1.06);
      box-shadow: 0 6px 16px rgba(176,85,120,.28);
    }
    .cb-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .cb-thumb--bottle img { object-fit: contain; background: linear-gradient(160deg, var(--theme-1), var(--theme-3)); }

    @media (max-width: 720px) {
      .cb-slider-wrap { width: 100%; max-width: 100%; }
      .cb-slider {
        height: clamp(380px, 90vw, 560px);
        border-radius: 18px;
        -webkit-mask-image: linear-gradient(to right, transparent 0%, #000 5%, #000 95%, transparent 100%);
                mask-image: linear-gradient(to right, transparent 0%, #000 5%, #000 95%, transparent 100%);
      }
      .cb-slider-track { gap: 16px; padding: 8px 0; }
      .cb-slide {
        width: min(82vw, 380px);
        max-width: 82vw;
        border-radius: 16px;
      }
      .cb-slide img { padding: 0; }
      .cb-arrow {
        width: 38px; height: 38px;
        font-size: 22px;
      }
      .cb-arrow--prev { left: 4px; }
      .cb-arrow--next { right: 4px; }
      .cb-thumbs { gap: 6px; margin-top: 16px; }
      .cb-thumb button { width: 44px; height: 56px; }
    }
    @media (max-width: 380px) {
      /* Very small phones (iPhone SE, etc.) — tighter sizing */
      .cb-slider { height: clamp(340px, 96vw, 460px); }
      .cb-slide { width: 88vw; max-width: 88vw; }
      .cb-thumb button { width: 38px; height: 48px; }
    }

    @media (prefers-reduced-motion: reduce) {
      .cb-slider-track,
      .cb-slide { transition: none; }
    }

    /* ─── SECTION SHARED ────────────────────────────────────────── */
    section { padding: 120px 48px; position: relative; }
    .inner { max-width: 1160px; margin: 0 auto; }
    .overline {
      font-size: 11px; font-weight: 700; letter-spacing: .32em;
      text-transform: uppercase; color: var(--accent-deep);
      margin-bottom: 18px;
    }
    .heading {
      font-family: var(--heading);
      font-size: clamp(32px, 4.5vw, 58px);
      font-weight: 300; line-height: 1.12;
      letter-spacing: -.01em;
      color: var(--ink);
      margin-bottom: 24px;
    }
    .lede {
      font-size: clamp(16px, 1.3vw, 19px);
      font-weight: 300;
      color: var(--warm-dim);
      line-height: 1.8;
      max-width: 620px;
    }

    /* Reveal — failsafe-first: starts hidden, but a CSS animation auto-
       reveals after 1.5s even if every JS animation library fails.
       When the JS observer adds .visible, the smooth transition takes
       over and the failsafe animation becomes a no-op. */
    @keyframes dc-reveal-failsafe {
      from { opacity: 0; transform: translateY(40px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .reveal { opacity: 0; transform: translateY(40px); animation: dc-reveal-failsafe .8s ease 1.5s forwards; }
    .reveal.visible { opacity: 1; transform: translateY(0); transition: opacity .8s ease, transform .8s ease; animation: none; }
    @media (prefers-reduced-motion: reduce) {
      .reveal { opacity: 1 !important; transform: none !important; animation: none !important; }
    }
    .reveal-delay-1 { transition-delay: .1s; }
    .reveal-delay-2 { transition-delay: .2s; }
    .reveal-delay-3 { transition-delay: .3s; }
    .reveal-delay-4 { transition-delay: .4s; }

    /* ─── THE PROMISE / PROBLEM ─────────────────────────────────── */
    #promise { background: #ffffff; }
    #promise .inner {
      display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;
    }
    .promise-img {
      background: linear-gradient(160deg, var(--theme-3) 0%, var(--theme-2) 100%);
      border-radius: 24px; padding: 60px;
      position: relative; overflow: hidden;
      aspect-ratio: 1/1;
      display: flex; align-items: center; justify-content: center;
    }
    .promise-img::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(circle at 30% 30%, rgba(255,255,255,.6) 0%, transparent 60%);
    }
    .promise-img-number {
      position: relative; z-index: 2;
      font-family: var(--heading);
      font-size: clamp(80px, 14vw, 220px);
      font-weight: 300;
      color: var(--accent-deep);
      line-height: 1;
      letter-spacing: -.04em;
    }
    .promise-img-number small {
      display: block; font-size: 14px; font-weight: 500;
      letter-spacing: .3em; text-transform: uppercase;
      color: var(--warm-dim); margin-top: 12px;
      letter-spacing: .25em;
    }
    .promise-text p {
      font-size: 15px; color: var(--warm-dim);
      line-height: 1.85; margin-bottom: 16px;
    }

    /* ─── INGREDIENT DEEP-DIVE ──────────────────────────────────── */
    #ingredients {
      background: linear-gradient(180deg, #fff8fa 0%, #fde4ec 100%);
      overflow: hidden;
    }
    #ingredients .inner { position: relative; }
    .ing-head { text-align: center; margin-bottom: 80px; }
    .ing-head .heading { max-width: 720px; margin-left: auto; margin-right: auto; }
    .ing-head .lede { margin: 20px auto 0; }
    .ing-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;
    }
    .ing-card {
      background: #ffffff;
      border: 1px solid rgba(0,0,0,.05);
      border-radius: 22px;
      padding: 36px 28px 32px;
      position: relative;
      transition: transform .4s cubic-bezier(.2,.8,.2,1), box-shadow .4s, border-color .4s;
    }
    .ing-card:hover {
      transform: translateY(-6px);
      border-color: rgba(224,122,158,.25);
      box-shadow: 0 20px 50px rgba(176,85,120,.14);
    }
    .ing-icon {
      width: 56px; height: 56px; border-radius: 16px;
      background: var(--accent-soft);
      color: var(--accent);
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 22px;
    }
    .ing-icon svg {
      width: 24px;
      height: 24px;
      stroke-width: 1.5;
    }
    .ing-name {
      font-family: var(--heading);
      font-size: 22px; font-weight: 400;
      color: var(--ink); margin-bottom: 10px;
    }
    .ing-dose {
      font-size: 14px; font-weight: 700; letter-spacing: .14em;
      text-transform: uppercase; color: var(--accent-deep);
      margin-bottom: 18px;
    }
    .ing-desc {
      font-size: 14px; font-weight: 300;
      color: var(--warm-dim);
      line-height: 1.75;
    }
    /* Bulleted ingredient details — rose dot in front of each line */
    .ing-list {
      margin: 0; padding: 0;
      list-style: none;
      display: flex; flex-direction: column;
      gap: 10px;
    }
    .ing-list li {
      position: relative;
      padding-left: 20px;
      font-size: 14px;
      font-weight: 400;
      color: var(--warm-dim);
      line-height: 1.55;
    }
    .ing-list li::before {
      content: '';
      position: absolute;
      left: 0; top: 8px;
      width: 7px; height: 7px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--accent), var(--accent-deep));
    }
    .ing-list li strong { color: var(--ink); font-weight: 600; }
    .ing-list li em {
      font-style: normal; color: var(--accent-deep);
      font-weight: 600;
    }
    .ing-list li.ing-list-note {
      padding-left: 20px;
      font-size: 12px;
      color: var(--muted);
      font-style: italic;
      margin-top: 4px;
    }
    .ing-list li.ing-list-note::before {
      background: transparent;
      border: 1px solid var(--muted);
      width: 6px; height: 6px;
      top: 9px;
    }

    /* ─── HOW IT WORKS / TIMELINE ───────────────────────────────── */
    #timeline {
      background: #ffffff;
      border-top: 1px solid rgba(0,0,0,.05);
    }
    .tl-head { text-align: center; margin-bottom: 80px; }
    .tl-head .heading { max-width: 720px; margin: 0 auto; }
    .tl-head .lede { margin: 20px auto 0; }
    .tl-grid {
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 0;
      border-top: 1px solid rgba(0,0,0,.08);
      border-bottom: 1px solid rgba(0,0,0,.08);
    }
    .tl-item {
      padding: 44px 28px;
      border-right: 1px solid rgba(0,0,0,.08);
      position: relative;
      transition: background .3s;
    }
    .tl-item:last-child { border-right: none; }
    .tl-item:hover { background: var(--theme-2); }
    .tl-week {
      font-family: var(--heading);
      font-size: 13px; font-weight: 500;
      letter-spacing: .28em; text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 18px;
    }
    .tl-num {
      font-family: var(--heading);
      font-size: 52px; font-weight: 300;
      color: var(--ink);
      margin-bottom: 14px; line-height: 1;
      letter-spacing: -.02em;
    }
    .tl-text {
      font-size: 14px; font-weight: 300;
      color: var(--warm-dim);
      line-height: 1.7;
    }

    /* ─── HOW TO USE ────────────────────────────────────────────── */
    #use {
      background: linear-gradient(180deg, #ffffff 0%, #fff5f8 100%);
      border-top: 1px solid rgba(0,0,0,.05);
    }
    #use .inner {
      display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;
    }
    .use-steps {
      list-style: none; display: flex; flex-direction: column; gap: 24px;
      margin-top: 36px;
    }
    .use-step {
      display: flex; align-items: flex-start; gap: 20px;
      padding: 22px 24px;
      background: #ffffff;
      border: 1px solid rgba(0,0,0,.06);
      border-radius: 16px;
      transition: border-color .3s, box-shadow .3s;
    }
    .use-step:hover {
      border-color: rgba(224,122,158,.28);
      box-shadow: 0 8px 24px rgba(176,85,120,.09);
    }
    .use-step-num {
      width: 38px; height: 38px; border-radius: 50%;
      background: var(--accent-soft);
      border: 1px solid rgba(224,122,158,.22);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--heading); font-size: 15px; font-weight: 500;
      color: var(--accent-deep);
      flex-shrink: 0;
    }
    .use-step-text h4 {
      font-size: 14px; font-weight: 500; color: var(--ink);
      margin-bottom: 4px; letter-spacing: .02em;
    }
    .use-step-text p {
      font-size: 13px; font-weight: 300; color: var(--warm-dim);
      line-height: 1.65;
    }
    .use-visual {
      position: relative;
    }
    .use-visual-bg {
      background: radial-gradient(ellipse at 50% 50%, var(--theme-1) 0%, var(--theme-2) 60%, transparent 100%);
      border-radius: 24px;
      aspect-ratio: 4/5;
      display: flex; align-items: center; justify-content: center;
      padding: 40px;
    }
    .use-visual-bg img {
      height: 100%; width: auto; max-height: 480px;
      filter: drop-shadow(0 30px 60px rgba(176,85,120,.26));
    }

    /* ─── RESULTS STATS ─────────────────────────────────────────── */
    #results {
      background: #ffffff;
      border-top: 1px solid rgba(0,0,0,.05);
    }
    .res-head { text-align: center; margin-bottom: 72px; }
    .res-head .heading { max-width: 720px; margin: 0 auto; }
    .res-head .lede { margin: 20px auto 0; }
    .res-grid {
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px;
      border: 1px solid rgba(0,0,0,.07);
      border-radius: 24px; overflow: hidden;
      background: rgba(0,0,0,.07);
    }
    .res-card {
      background: #ffffff;
      padding: 48px 24px;
      text-align: center;
    }
    .res-num {
      font-family: var(--heading);
      font-size: clamp(32px, 4.2vw, 56px);
      font-weight: 300;
      color: var(--ink); line-height: 1;
      margin-bottom: 14px;
    }
    .res-num span { color: var(--accent); }
    .res-label {
      font-size: 11px; font-weight: 500; letter-spacing: .2em;
      text-transform: uppercase; color: var(--muted);
      line-height: 1.5;
    }
    .res-foot {
      text-align: center; margin-top: 36px;
      font-size: 12px; font-style: italic; color: var(--muted);
    }

    /* ─── TESTIMONIALS ──────────────────────────────────────────── */
    #reviews {
      background: linear-gradient(180deg, #ffffff 0%, #fde4ec 100%);
      overflow: hidden;
      border-top: 1px solid rgba(0,0,0,.05);
    }
    .rev-head { text-align: center; margin-bottom: 56px; }
    .rev-head .heading { max-width: 720px; margin: 0 auto; }

    /* ─── Edge-to-edge marquee (right → left, continuous) ──────── */
    .rev-marquee {
      position: relative;
      left: 50%;
      right: 50%;
      width: 100vw;
      max-width: 100vw;
      margin-left: -50vw;
      margin-right: -50vw;
      overflow: hidden;
    }
    .rev-marquee-track {
      display: flex;
      gap: 24px;
      width: max-content;
      padding: 8px 0;
      animation: rev-scroll 90s linear infinite;
      will-change: transform;
    }
    .rev-marquee:hover .rev-marquee-track,
    .rev-marquee:focus-within .rev-marquee-track {
      animation-play-state: paused;
    }
    @keyframes rev-scroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    @media (prefers-reduced-motion: reduce) {
      .rev-marquee-track { animation: none; }
    }

    .rev-card {
      flex: 0 0 auto;
      width: 360px;
      background: #ffffff;
      border: 1px solid rgba(0,0,0,.06);
      border-radius: 20px;
      padding: 32px 28px;
      transition: transform .3s, box-shadow .3s;
    }
    .rev-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 16px 40px rgba(176,85,120,.12);
    }
    .rev-stars {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 14px;
    }
    /* Reliable fractional-star rendering: a filled layer is clipped to
       --rating (% width) over a faint empty track of the same five stars.
       100% = 5 stars, 90% = 4.5, 80% = 4 — no decimals leak into the row. */
    .rev-stars-track {
      --rating: 100%;
      position: relative;
      display: inline-block;
      font-size: 14px;
      letter-spacing: 2px;
      line-height: 1;
      white-space: nowrap;
    }
    .rev-stars-track::before {
      content: "★★★★★";
      color: rgba(176, 85, 120, 0.24);
    }
    .rev-stars-track::after {
      content: "★★★★★";
      color: var(--accent-deep);
      position: absolute;
      inset: 0;
      width: var(--rating);
      overflow: hidden;
    }
    .rev-rating-num {
      font-size: 12px;
      letter-spacing: .05em;
      color: var(--muted);
    }

    @media (max-width: 720px) {
      .rev-card { width: 280px; padding: 26px 22px; }
      .rev-marquee-track { gap: 16px; animation-duration: 70s; }
    }
    .rev-quote { font-size: 15px; font-weight: 300; font-style: italic;
      color: var(--warm-dim); line-height: 1.75; margin-bottom: 22px; }
    .rev-author { display: flex; align-items: center; gap: 12px; }
    .rev-avatar {
      width: 40px; height: 40px; border-radius: 50%;
      background: linear-gradient(135deg, var(--accent), var(--accent-deep));
      display: flex; align-items: center; justify-content: center;
      font-size: 14px; font-weight: 600; color: #fff;
    }
    .rev-name { font-size: 13px; font-weight: 500; color: var(--ink); }
    .rev-role { font-size: 11px; font-weight: 300; color: var(--muted); }

    /* ─── FAQ ───────────────────────────────────────────────────── */
    #faq {
      background: #ffffff;
      border-top: 1px solid rgba(0,0,0,.05);
    }
    .faq-head { text-align: center; margin-bottom: 60px; }
    .faq-head .heading { max-width: 600px; margin: 0 auto; }
    .faq-list {
      max-width: 760px; margin: 0 auto;
      display: flex; flex-direction: column; gap: 14px;
    }
    .faq-item {
      background: #fdf6f8;
      border: 1px solid rgba(0,0,0,.06);
      border-radius: 14px;
      overflow: hidden;
      transition: border-color .3s, background .3s;
    }
    .faq-item[open] { border-color: rgba(224,122,158,.32); background: #fff; }
    .faq-item summary {
      list-style: none;
      padding: 22px 26px;
      font-size: 15px; font-weight: 500; color: var(--ink);
      cursor: pointer;
      display: flex; justify-content: space-between; align-items: center;
      gap: 20px;
      transition: color .3s;
    }
    .faq-item summary::-webkit-details-marker { display: none; }
    .faq-item summary:hover { color: var(--accent-deep); }
    .faq-item summary::after {
      content: '+';
      font-size: 24px; font-weight: 300;
      color: var(--accent);
      transition: transform .3s;
    }
    .faq-item[open] summary::after { transform: rotate(45deg); }
    .faq-answer {
      padding: 0 26px 22px;
      font-size: 14px; font-weight: 300;
      color: var(--warm-dim); line-height: 1.8;
    }

    /* ─── FINAL CTA ─────────────────────────────────────────────── */
    #cta {
      background: linear-gradient(135deg, var(--theme-1) 0%, var(--theme-2) 50%, var(--theme-3) 100%);
      text-align: center;
      padding: 140px 48px;
      position: relative; overflow: hidden;
    }
    #cta::before {
      content: '';
      position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
      width: 700px; height: 700px; border-radius: 50%;
      background: radial-gradient(circle, rgba(224,122,158,.14) 0%, transparent 60%);
      pointer-events: none;
    }
    .cta-inner { position: relative; z-index: 2; max-width: 720px; margin: 0 auto; }
    .cta-inner .heading {
      font-size: clamp(36px, 5.5vw, 72px);
      margin-bottom: 24px;
    }
    .cta-inner .lede {
      margin: 0 auto 40px; font-size: 17px;
    }
    .cta-actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
    .cta-guarantee {
      margin-top: 32px;
      font-size: 11px; letter-spacing: .15em; text-transform: uppercase;
      color: var(--warm-dim);
    }
    .cta-guarantee span { color: var(--accent-deep); font-weight: 600; }

    /* ─── FOOTER ────────────────────────────────────────────────── */
    footer {
      background: #1a1225;
      color: rgba(255,255,255,.55);
      padding: 64px 48px 32px;
    }
    .footer-inner {
      max-width: 1160px; margin: 0 auto;
      display: flex; justify-content: space-between; align-items: center;
      flex-wrap: wrap; gap: 24px;
    }
    .footer-brand {
      font-family: var(--heading);
      font-size: 20px; font-weight: 600;
      color: #fff;
      letter-spacing: .08em;
    }
    .footer-brand span { color: var(--accent); }
    .footer-legal { font-size: 11px; color: rgba(255,255,255,.4); }
    .footer-links { display: flex; gap: 24px; }
    .footer-links a {
      font-size: 12px; color: rgba(255,255,255,.6); letter-spacing: .08em;
      transition: color .3s;
    }
    .footer-links a:hover { color: var(--accent); }

    /* ─── RESPONSIVE ────────────────────────────────────────────── */
    @media (max-width: 900px) {
      nav { padding: 18px 24px; }
      nav.scrolled { padding: 12px 24px; }
      section { padding: 80px 24px; }
      #hero { grid-template-columns: 1fr; gap: 40px; padding: 120px 24px 60px; }
      .hero-text { order: 2; }
      .hero-visual { order: 1; }
      .hero-badge-float { display: none; }
      #promise .inner, #use .inner { grid-template-columns: 1fr; gap: 40px; }
      .ing-grid { grid-template-columns: 1fr 1fr; }
      .tl-grid { grid-template-columns: 1fr 1fr; }
      .tl-item { border-right: none; border-bottom: 1px solid rgba(0,0,0,.08); }
      .tl-item:nth-child(odd) { border-right: 1px solid rgba(0,0,0,.08); }
      .tl-item:nth-last-child(-n+2) { border-bottom: none; }
      .res-grid { grid-template-columns: 1fr 1fr; }
      /* .rev-grid removed in v23 — now using .rev-marquee instead */
      .nav-back span:not(.arrow) { display: none; }
    }
    @media (max-width: 600px) {
      nav { padding: 16px 20px; }
      nav.scrolled { padding: 12px 20px; }
      .nav-logo { font-size: 17px; }
      .nav-cta { padding: 8px 16px; font-size: 10px; }
      section { padding: 64px 20px; }
      #cta { padding: 96px 20px; }
      .hero-title { font-size: clamp(42px, 11vw, 64px); }
      .hero-actions { flex-direction: column; align-items: stretch; }
      .hero-actions .btn-primary, .hero-actions .btn-outline { text-align: center; }
      .ing-grid { grid-template-columns: 1fr; }
      .footer-inner { flex-direction: column; text-align: center; }
      #film-grain { display: none; }
    }
    @media (prefers-reduced-motion: reduce) {
      *,*::before,*::after { animation-duration: .01ms !important; transition-duration: .01ms !important; }
    }
  
    /* ─── FOCUS VISIBILITY (WCAG 2.4.7) ─────────────────────────── */
    :focus { outline: none; }
    a:focus-visible, button:focus-visible, details > summary:focus-visible,
    .btn-primary:focus-visible, .btn-outline:focus-visible, .nav-cta:focus-visible,
    [tabindex]:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 3px;
      border-radius: 8px;
    }
    .skip-link {
      position: absolute; left: -9999px; top: 0; z-index: 10000;
      padding: 12px 18px; background: var(--ink); color: #fff;
      font-size: 12px; font-weight: 600; letter-spacing: .2em;
      text-transform: uppercase; border-radius: 0 0 10px 0;
    }
    .skip-link:focus { left: 0; outline: 2px solid var(--accent); outline-offset: 2px; }

    /* ─── HAMBURGER + DRAWER ─────────────────────────────────────── */
    .nav-hamburger {
      display: none; width: 44px; height: 44px; padding: 0;
      background: transparent; border: none; position: relative; cursor: pointer;
    }
    .nav-hamburger span {
      position: absolute; left: 10px; right: 10px; height: 1.5px;
      background: var(--ink); border-radius: 2px;
      transition: transform .3s ease, opacity .3s ease, top .3s ease;
    }
    .nav-hamburger span:nth-child(1) { top: 15px; }
    .nav-hamburger span:nth-child(2) { top: 21px; }
    .nav-hamburger span:nth-child(3) { top: 27px; }
    .nav-hamburger[aria-expanded="true"] span:nth-child(1) { top: 21px; transform: rotate(45deg); }
    .nav-hamburger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
    .nav-hamburger[aria-expanded="true"] span:nth-child(3) { top: 21px; transform: rotate(-45deg); }
    #mobile-drawer {
      position: fixed; inset: 0; z-index: 490;
      background: rgba(255,255,255,.98);
      backdrop-filter: blur(20px) saturate(130%);
      -webkit-backdrop-filter: blur(20px) saturate(130%);
      display: flex; flex-direction: column;
      padding: 96px 32px 40px;
      opacity: 0; visibility: hidden; transform: translateY(-8px);
      transition: opacity .3s ease, transform .3s ease, visibility .3s ease;
    }
    #mobile-drawer.open { opacity: 1; visibility: visible; transform: translateY(0); }
    #mobile-drawer .drawer-links { list-style: none; display: flex; flex-direction: column; gap: 4px; margin: 0; padding: 0; }
    #mobile-drawer .drawer-links > li > a,
    #mobile-drawer .drawer-links .drawer-heading {
      display: block; padding: 16px 12px;
      font-family: var(--heading); font-size: 22px; font-weight: 400;
      color: var(--ink); letter-spacing: .02em;
      border-bottom: 1px solid rgba(0,0,0,.06);
    }
    #mobile-drawer .drawer-sub {
      list-style: none; padding: 4px 0 12px 16px; margin: 0;
      display: flex; flex-direction: column; gap: 2px;
      border-bottom: 1px solid rgba(0,0,0,.06);
    }
    #mobile-drawer .drawer-sub a {
      display: block; padding: 10px 12px; font-family: var(--body);
      font-size: 14px; color: var(--ink); letter-spacing: .02em;
    }
    #mobile-drawer .drawer-sub a em {
      font-style: normal; color: var(--muted);
      font-size: 11px; letter-spacing: .14em; text-transform: uppercase; margin-left: 6px;
    }
    #mobile-drawer .drawer-cta { margin-top: auto; padding-top: 24px; display: flex; justify-content: center; }
    body.drawer-open { overflow: hidden; }

    @media (max-width: 900px) {
      .nav-back { display: none; }
      .nav-hamburger { display: block; }
    }

    /* ─── ELEVATION: CURSOR / PARTICLES / SPLIT / TILT ──────────── */
    #cursor-dot {
      position: fixed; top: 0; left: 0; z-index: 9998;
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--ink); pointer-events: none;
      transform: translate(-50%,-50%);
      mix-blend-mode: difference;
      transition: width .2s, height .2s;
    }
    #cursor-ring {
      position: fixed; top: 0; left: 0; z-index: 9997;
      width: 34px; height: 34px; border-radius: 50%;
      border: 1.5px solid var(--accent);
      pointer-events: none;
      transform: translate(-50%,-50%);
      transition: border-color .3s, width .3s, height .3s, box-shadow .3s;
    }
    body.hovering #cursor-ring {
      width: 54px; height: 54px;
      box-shadow: 0 0 18px var(--accent-glow);
      border-color: var(--accent-deep);
    }
    #particles-canvas {
      position: fixed; inset: 0; z-index: 15;
      pointer-events: none; opacity: .55;
    }
    @media (max-width: 899px) {
      #cursor-dot, #cursor-ring { display: none; }
      #particles-canvas { opacity: .3; }
    }
    @media (hover: none) {
      #cursor-dot, #cursor-ring { display: none; }
    }
    @media (prefers-reduced-motion: reduce) {
      #particles-canvas { display: none; }
      .split-char { opacity: 1 !important; transform: none !important; animation: none !important; }
    }

    .split-word { display: inline-block; white-space: nowrap; }
    .split-char {
      display: inline-block; opacity: 0;
      transform: translateY(26px);
      animation: split-char-in .6s cubic-bezier(.22,.9,.32,1) forwards;
    }
    @keyframes split-char-in {
      from { opacity: 0; transform: translateY(26px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .ing-card {
      transform-style: preserve-3d;
